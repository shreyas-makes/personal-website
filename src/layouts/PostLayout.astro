---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import NewsletterFormWithHeaders from '../components/NewsletterFormWithHeaders.astro';
import { formatDate } from '../utils/formatDate';
import { calculateReadingTime } from '../utils/readingTime';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import GrowthStage from '../components/GrowthStage.astro';
import { incrementPageView, getPopularPosts } from '../utils/pageViews';
import { siteConfig } from '../utils/config';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const readingTime = calculateReadingTime(post.body);
const formattedDate = formatDate(post.data.date);

// Function to get the GitHub edit URL for the post
const getGitHubEditUrl = (post: CollectionEntry<'posts'>) => {
  // Use post.data.title if available (assuming title matches filename), otherwise use post.id
  const filename = post.data.title ? 
    `${post.data.title}.md` : 
    `${post.id}.md`;
  
  return `https://github.com/shreyas-makes/astro-blog-ghost/edit/main/src/content/posts/${encodeURIComponent(filename)}`;
};

// Track page view for this post
if (Astro.request.method === 'GET') {
  // Only track views on actual page loads, not during SSR
  // This is a client-side operation that will be handled by the script below
}

// Get popular posts
const allPosts = await getCollection('posts', ({ id, data }) => !data.draft);

// Fallback to random posts if we can't get popular posts
let popularPosts = [];
try {
  // Attempt to get popular posts from the API
  popularPosts = await getPopularPosts(5);
  
  // If we don't have enough popular posts, supplement with random ones
  if (popularPosts.length < 5) {
    const randomPosts = allPosts
      .filter(p => 
        p.id !== post.id && // Exclude current post
        !p.data.tags?.includes('books') && // Exclude books
        !p.data.tags?.includes('projects') && // Exclude projects
        !['about', 'now', 'vibes'].includes(p.slug) && // Exclude specific pages
        !popularPosts.some(pp => pp.id === p.id) // Exclude posts already in popular list
      )
      .sort(() => Math.random() - 0.5) // Randomize order
      .slice(0, 5 - popularPosts.length); // Take enough to reach 5 total
    
    popularPosts = [...popularPosts, ...randomPosts];
  }
} catch (error) {
  console.error('Error fetching popular posts:', error);
  
  // Fallback to random posts
  popularPosts = allPosts
    .filter(p => 
      p.id !== post.id && // Exclude current post
      !p.data.tags?.includes('books') && // Exclude books
      !p.data.tags?.includes('projects') && // Exclude projects
      !['about', 'now', 'vibes'].includes(p.slug) // Exclude specific pages
    )
    .sort(() => Math.random() - 0.5) // Randomize order
    .slice(0, 5); // Take 5 posts
}

// Store API path for client-side use
const pageViewsEndpoint = siteConfig.api.pageViews;

// Add Prism.js copy button functionality with direct API endpoint value
const prismCopyButtonScript = `
  document.addEventListener('DOMContentLoaded', (event) => {
    // Add copy button to code blocks
    document.querySelectorAll('pre').forEach((block) => {
      // Create button
      const button = document.createElement('button');
      button.className = 'copy-button';
      button.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>';
      button.setAttribute('aria-label', 'Copy code to clipboard');
      
      // Add button to code block
      block.style.position = 'relative';
      block.appendChild(button);
      
      // Add click handler
      button.addEventListener('click', async () => {
        const code = block.querySelector('code');
        const text = code.innerText;
        
        try {
          await navigator.clipboard.writeText(text);
          button.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg>';
          setTimeout(() => {
            button.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>';
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
          button.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 13h-1v-1h1v1zm0-3h-1V7h1v5z"></path></svg>';
        }
      });
    });
    
    // Track page view
    try {
      const slug = window.location.pathname.replace(/^\/posts\//, '').replace(/\/$/, '');
      if (slug) {
        // Get the base URL and construct the API URL
        const baseUrl = window.location.origin;
        const pageViewsEndpoint = '/api/pageViews'; // Hard-coded endpoint path
        const url = new URL(pageViewsEndpoint, baseUrl);
        
        fetch(url.toString(), {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ slug }),
        });
      }
    } catch (error) {
      console.error('Error tracking page view:', error);
    }
  });
`;

console.log("Post data in PostLayout:", post.data); // Debug log
console.log("Stage value in PostLayout:", post.data.stage); // Debug log
---

<BaseLayout title={`${post.data.title} | Shreyas`}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-6">
    {post.data.image && (
      <Image
        src={post.data.image}
        alt={post.data.title}
        width={1200}
        height={630}
        format="webp"
        loading="eager"
        class="rounded-lg mb-8"
      />
    )}
    
    {/* Updated Title and Metadata Section - Restructured */}
    <div class="mb-6 sm:mb-2"> {/* Container for all header elements */}
      <h1 class="text-xl sm:text-2xl md:text-3xl font-normal text-gray-900 dark:text-gray-100 mb-5 sm:mb-4 leading-relaxed">
        {post.data.title}
      </h1>

      {/* Growth Stage - Separate placement */}
      <div class="mb-2">
        <GrowthStage stage={post.data.stage || 'seedling'} />
      </div>
      
      {/* All metadata in one structured line */}
      <div class="flex flex-wrap items-center gap-x-2 text-sm text-gray-600 dark:text-gray-400 font-['Verdana',_Geneva,_sans-serif]">
        {/* Tag if available */}
        {post.data.tags && post.data.tags.length > 0 && (
          <>
            <a 
              href={`/tags/${post.data.tags[0]}`} 
              class="hover:text-gray-800 dark:hover:text-gray-200 transition-colors duration-200"
            >
              #{post.data.tags[0]}
            </a>
            <span class="text-gray-400 dark:text-gray-600">&bull;</span>
          </>
        )}
        <span>{readingTime}</span>
        <span class="text-gray-400 dark:text-gray-600">&bull;</span>
        <span>{formattedDate}</span>
      </div>
    </div>
    
    {/* Add debug info */}
    <!-- {JSON.stringify(post.data)} -->
    
    
    <div class="mt-2 prose prose-neutral dark:prose-invert max-w-none">
      <slot />
    </div>
    
    <!-- Post End Divider -->
    <div class="my-12 flex justify-center" aria-hidden="true">
      <img src="/images/page-divider.png" alt="" class="h-8 w-auto opacity-70 dark:opacity-60" />
    </div>
  </article>
  <!-- GitHub Pull Request Byline -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 mb-12 text-center">
    <div class="p-4 border border-gray-200 dark:border-gray-800 rounded-lg bg-gray-50 dark:bg-gray-900">
      <p class="text-sm text-gray-600 dark:text-gray-400">
        Found a typo or want to suggest changes? 
        <a 
          href={getGitHubEditUrl(post)}
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-800 dark:text-gray-200 hover:text-gray-600 dark:hover:text-gray-400 underline underline-offset-4 decoration-1"
        >
         Send a PR on GitHub
        </a>
      </p>
    </div>
  </div>

  <!-- Newsletter Form -->
  <NewsletterFormWithHeaders />

  <!-- Popular Posts Section -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 mb-12">
    <h2 class="text-xl sm:text-xl font-normal text-gray-800 dark:text-gray-300 mb-8">
      Here are some popular posts you might like
    </h2>
    <div class="space-y-8">
      {popularPosts.map((popularPost) => {
        // Get first three lines as excerpt
        const lines = popularPost.body.split('\n').slice(0,3);
        const excerpt = lines.join('\n') + '...';
        
        return (
          <div class="flex flex-col">
            <a href={`/posts/${popularPost.slug}`} 
               class="text-gray-800 dark:text-gray-200 hover:text-gray-600 dark:hover:text-gray-400 text-base sm:text-lg font-normal underline underline-offset-4 decoration-1 mb-2">
              {popularPost.data.title}
            </a>
            <p class="text-gray-600 dark:text-gray-300 text-sm sm:text-base mb-3 line-clamp-2">
              {excerpt}
            </p>
            <div class="flex justify-between">
              <span class="text-gray-500 dark:text-gray-400 text-xs sm:text-sm">
                {popularPost.data.tags && popularPost.data.tags.length > 0 ? popularPost.data.tags[0] : 'post'}
              </span>
              {popularPost.views && (
                <span class="text-gray-500 dark:text-gray-400 text-xs sm:text-sm flex items-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                  </svg>
                  {popularPost.views}
                </span>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  /* Keep only essential styles */
  :global(.prose) {
    max-width: none;
    overflow-wrap: break-word;
    word-wrap: break-word;
    word-break: normal;
    hyphens: auto;
    font-size: 16px;
    line-height: 27px;
    font-family: 'Verdana', Geneva, sans-serif;
    font-weight: 400;
  }
  
  :global(.prose h1, .prose h2, .prose h3, .prose h4, .prose h5, .prose h6) {
    font-weight: 400;
    color: var(--text);
    overflow-wrap: break-word;
    word-wrap: break-word;
  }
  
  :global(.prose h1) {
    font-size: 1.5em;
    margin-top: 2em;
    margin-bottom: 1em;
    line-height: 1.5;
  }
  
  :global(.prose h2) {
    font-size: 1.3em;
    margin-top: 1.75em;
    margin-bottom: 0.75em;
  }
  
  :global(.prose h3) {
    font-size: 1.1em;
    margin-top: 1.5em;
    margin-bottom: 0.75em;
  }
  
  :global(.prose p) {
    color: var(--text);
    overflow-wrap: break-word;
    word-wrap: break-word;
    margin-bottom: 2.5em;
  }

  :global(.prose li) {
    color: var(--text);
    overflow-wrap: break-word;
    word-wrap: break-word;
    margin-bottom: 0.5em;
  }

  :global(.prose blockquote) {
    color: var(--text);
    border-left: 4px solid #e5e7eb;
    overflow-wrap: break-word;
    word-wrap: break-word;
    padding-right: 1rem;
  }

  :global(.prose a) {
    color: var(--text);
    text-decoration-line: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    overflow-wrap: break-word;
    word-wrap: break-word;
    word-break: break-word;
  }

  /* Code block styles with improved mobile handling */
  :global(.prose code) {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.8em;  /* Slightly smaller than surrounding text */
    font-weight: 400;   /* Lighter weight for better readability */
    color: #abb2bf;
    background-color: #282c34;
    padding: 0.2em 0.4em;
    border-radius: 0.25em;
    white-space: pre-wrap;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  :global(.prose pre) {
    background-color: #282c34;
    border-radius: 0.5em;
    margin: 1.5em 0;
    padding: 1em 0.5em 1em 0;
    position: relative;
    overflow-x: hidden;
    width: 100%;
    box-sizing: border-box;
  }

  /* Ensure code blocks within pre tags don't get the inline styling */
  :global(.prose pre code) {
    background-color: transparent;
    padding: 0 1em 0 2.5rem; /* Increased left padding for better readability */
    border-radius: 0;
    color: inherit;
    font-size: 0.875em;
    font-family: 'JetBrains Mono', 'Fira Code', 'Roboto Mono', monospace;
    display: block;
    white-space: pre-wrap;
    word-wrap: break-word;
    word-break: break-word;
    overflow-wrap: anywhere; /* Ensure long words can break */
    width: 100%;
    box-sizing: border-box;
  }

  /* Ensure prose content doesn't have width restrictions */
  :global(.prose) {
    max-width: none !important;
    overflow-x: hidden;
  }

  /* Ensure content doesn't overflow */
  article {
    width: 100%;
    overflow-x: hidden;
    box-sizing: border-box;
  }

  /* Make sure images stay within container */
  :global(.prose img) {
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  /* Make blockquotes responsive */
  :global(.quoteback) {
    max-width: 100%;
    overflow-wrap: break-word;
    word-wrap: break-word;
    box-sizing: border-box;
  }

  /* Table styles are now in global.css */

  /* Add responsive styles for related posts section */
  @media (max-width: 640px) {
    .grid-cols-[120px_1fr] {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    
    :global(.prose) {
      font-size: 15px;
      line-height: 24px;
    }
    
    :global(.prose p) {
      margin-bottom: 2.5em; /* Keep the same increased spacing on mobile */
    }
    
    :global(.prose li) {
      margin-bottom: 0.5em; /* Keep the reduced spacing for list items on mobile */
    }
    
    :global(.prose h1) {
      font-size: 1.3em;
      margin-top: 1.5em;
      margin-bottom: 0.8em;
      line-height: 1.4;
    }
    
    :global(.prose h2) {
      font-size: 1.1em;
      margin-top: 1.75em;
      margin-bottom: 0.75em;
    }
    
    :global(.prose h3) {
      font-size: 1em;
      margin-top: 1.5em;
      margin-bottom: 0.75em;
    }
    
    :global(.prose pre) {
      margin-left: -1.25rem;
      margin-right: -1.25rem;
      border-radius: 0;
      width: 100%;
      padding: 1em 0.5em 1em 0.5em;
      overflow-x: hidden;
    }
    
    :global(.prose pre code) {
      padding-left: 2rem; /* Increased left padding on mobile */
      font-size: 0.8em;
      overflow-x: hidden;
      white-space: pre-wrap;
      word-break: break-all;
      overflow-wrap: break-word;
    }
    
    :global(.prose blockquote) {
      margin-left: 0;
      margin-right: 0;
      padding-left: 1rem;
    }
    
    /* Adjust article padding on mobile */
    article.max-w-3xl {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }
    
    /* Adjust link behavior on mobile */
    :global(.prose a) {
      word-break: break-word;
      display: inline-block; /* Helps with breaking long URLs */
      max-width: 100%;
    }
  }

  /* Dark mode overrides with higher specificity */
  :global(html.dark .prose h1),
  :global(html.dark .prose h2),
  :global(html.dark .prose h3),
  :global(html.dark .prose h4),
  :global(html.dark .prose h5),
  :global(html.dark .prose h6) {
    color: var(--text);
  }

  :global(html.dark .prose p),
  :global(html.dark .prose li) {
    color: var(--text);
  }

  :global(html.dark .prose blockquote) {
    color: #9ca3af;
    border-left-color: #374151;
  }

  :global(html.dark .prose strong) {
    color: var(--text);
  }

  :global(html.dark .prose a) {
    color: var(--text);
  }

  /* Copy button styles */
  :global(.copy-button) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #abb2bf;
    background-color: #353b45;
    border: 1px solid #454d5b;
    border-radius: 0.375rem;
    opacity: 0;
    transition: all 0.2s ease;
    cursor: pointer;
    width: 32px;
    height: 32px;
  }

  :global(.copy-button svg) {
    width: 16px;
    height: 16px;
    stroke-width: 2px;
  }

  :global(.prose pre:hover .copy-button) {
    opacity: 1;
  }

  :global(.copy-button:hover) {
    background-color: #454d5b;
    color: #ffffff;
    transform: scale(1.05);
  }

  :global(.copy-button:active) {
    transform: scale(0.95);
  }

  :global(.copy-button:focus) {
    outline: 2px solid #61afef;
    outline-offset: 2px;
  }

  /* Add a subtle line number effect */
  :global(.prose pre) {
    counter-reset: line;
  }
</style>

<script set:html={prismCopyButtonScript} /> 