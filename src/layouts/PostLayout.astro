---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import NewsletterFormWithHeaders from '../components/NewsletterFormWithHeaders.astro';
import { formatDate } from '../utils/formatDate';
import { calculateReadingTime } from '../utils/readingTime';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import GrowthStage from '../components/GrowthStage.astro';
import { incrementPageView, getPopularPosts } from '../utils/pageViews';
import { siteConfig } from '../utils/config';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const readingTime = calculateReadingTime(post.body);
const formattedDate = formatDate(post.data.date);

// Function to get the GitHub edit URL for the post
const getGitHubEditUrl = (post: CollectionEntry<'posts'>) => {
  // Use post.data.title if available (assuming title matches filename), otherwise use post.id
  const filename = post.data.title ? 
    `${post.data.title}.md` : 
    `${post.id}.md`;
  
  return `https://github.com/shreyas-makes/astro-blog-ghost/edit/main/src/content/posts/${encodeURIComponent(filename)}`;
};

// Track page view for this post
if (Astro.request.method === 'GET') {
  // Only track views on actual page loads, not during SSR
  // This is a client-side operation that will be handled by the script below
}

// Get popular posts
const allPosts = await getCollection('posts', ({ id, data }) => !data.draft);

// Fallback to random posts if we can't get popular posts
let popularPosts = [];
try {
  // Attempt to get popular posts from the API
  popularPosts = await getPopularPosts(5);
  
  // If we don't have enough popular posts, supplement with random ones
  if (popularPosts.length < 5) {
    const randomPosts = allPosts
      .filter(p => 
        p.id !== post.id && // Exclude current post
        !p.data.tags?.includes('books') && // Exclude books
        !p.data.tags?.includes('projects') && // Exclude projects
        !['about', 'now', 'vibes'].includes(p.slug) && // Exclude specific pages
        !popularPosts.some(pp => pp.id === p.id) // Exclude posts already in popular list
      )
      .sort(() => Math.random() - 0.5) // Randomize order
      .slice(0, 5 - popularPosts.length); // Take enough to reach 5 total
    
    popularPosts = [...popularPosts, ...randomPosts];
  }
} catch (error) {
  console.error('Error fetching popular posts:', error);
  
  // Fallback to random posts
  popularPosts = allPosts
    .filter(p => 
      p.id !== post.id && // Exclude current post
      !p.data.tags?.includes('books') && // Exclude books
      !p.data.tags?.includes('projects') && // Exclude projects
      !['about', 'now', 'vibes'].includes(p.slug) // Exclude specific pages
    )
    .sort(() => Math.random() - 0.5) // Randomize order
    .slice(0, 5); // Take 5 posts
}

// Store API path for client-side use
const pageViewsEndpoint = siteConfig.api.pageViews;

// Add Prism.js copy button functionality with direct API endpoint value
const prismCopyButtonScript = `
  document.addEventListener('DOMContentLoaded', (event) => {
    // Add copy button to code blocks
    document.querySelectorAll('pre').forEach((block) => {
      // Create button
      const button = document.createElement('button');
      button.className = 'copy-button';
      button.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>';
      button.setAttribute('aria-label', 'Copy code to clipboard');
      
      // Add button to code block
      block.style.position = 'relative';
      block.appendChild(button);
      
      // Add click handler
      button.addEventListener('click', async () => {
        const code = block.querySelector('code');
        const text = code.innerText;
        
        try {
          await navigator.clipboard.writeText(text);
          button.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg>';
          setTimeout(() => {
            button.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>';
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
          button.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 13h-1v-1h1v1zm0-3h-1V7h1v5z"></path></svg>';
        }
      });
    });
    
    // Track page view
    try {
      const slug = window.location.pathname.replace(/^\/posts\//, '').replace(/\/$/, '');
      if (slug) {
        // Get the base URL and construct the API URL
        const baseUrl = window.location.origin;
        const pageViewsEndpoint = '/api/pageViews'; // Hard-coded endpoint path
        const url = new URL(pageViewsEndpoint, baseUrl);
        
        fetch(url.toString(), {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ slug }),
        });
      }
    } catch (error) {
      console.error('Error tracking page view:', error);
    }
  });
`;

console.log("Post data in PostLayout:", post.data); // Debug log
console.log("Stage value in PostLayout:", post.data.stage); // Debug log
---

<BaseLayout title={`${post.data.title} | Shreyas`}>
  <div class="mt-0 sm:mt-12 md:mt-12 max-w-4xl mx-auto px-4 sm:px-6 py-6">
    <!-- Two Column Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_200px] gap-8 lg:gap-12">
      <!-- Main Content Column -->
      <article class="min-w-0">
        {post.data.image && (
          <Image
            src={post.data.image}
            alt={post.data.title}
            width={1200}
            height={630}
            format="webp"
            loading="eager"
            class="rounded-lg mb-8"
          />
        )}
        
        {/* Updated Header Section - Centered DHH Style */}
        <div class="mb-12 text-center">
          
             {/* Author Image */}
          <div class="mt-8 flex justify-center mb-4">
            <img 
              src="https://0.gravatar.com/avatar/991d6680b622c30f9c9e06b25ab884e4e6a18dd35deac1a61f7c9464e1a6d1c3?size=256"
              alt="Shreyas Prakash"
              class="w-16 h-16 rounded-full object-cover border-2 border-black dark:border-black"
            />
          </div>
          
          {/* Title */}
          <h2 class="text-2xl sm:text-3xl md:text-2xl lg:text-4xl font-bold text-gray-900 dark:text-gray-100 leading-tight max-w-4xl mx-auto">
            {post.data.title}
          </h1>
          
          {/* Optional metadata below title */}
          <div class="flex justify-center items-center gap-4 mt-6 text-xs text-gray-500 dark:text-gray-500">
            <div class="flex items-center gap-1 px-2 py-1 bg-gray-50 dark:bg-gray-800/50 rounded-full">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-xs">{Math.ceil(post.body.split(/\s+/).length / 200)} min read</span>
            </div>
            
            {/* Tags - Only show first tag excluding rough-notes */}
            {post.data.tags && (
              (() => {
                const visibleTags = post.data.tags.filter(tag => tag !== 'rough-notes').slice(0, 1);
                return visibleTags.length > 0 ? (
                  <a
                    href={`/tags/${visibleTags[0]}`}
                    class="px-2 py-1 bg-gray-50 dark:bg-gray-800/50 rounded-full text-xs hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                  >
                    #{visibleTags[0]}
                  </a>
                ) : null;
              })()
            )}
            <time datetime={post.data.date.toISOString()} class="text-xs px-2 py-1 bg-gray-50 dark:bg-gray-800/50 rounded-full">
              {new Date(post.data.date).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </time>
          </div>
        </div>
        
        <div class="mt-2 prose prose-neutral dark:prose-invert max-w-none">
          <slot />
        </div>
        <!-- Post Footer Section -->
        <div class="mt-2 mb-12">
          <div class="max-w-2xl mx-auto">
            <!-- GitHub PR Section -->
            <div class="text-center py-6">
              <p class="text-sm text-gray-500 dark:text-gray-500">
                Found a typo or want to suggest changes? 
                <a 
                  href={getGitHubEditUrl(post)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-2 decoration-1 transition-colors"
                >
                  Send a PR on GitHub
                </a>
              </p>
            </div>
            
            <!-- Subtle Divider -->
            <div class="flex items-center justify-center py-8">
              <div class="flex-1 border-t border-gray-200 dark:border-gray-800"></div>
              <div class="px-4">
                <svg class="w-4 h-4 text-gray-300 dark:text-gray-700" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="flex-1 border-t border-gray-200 dark:border-gray-800"></div>
            </div>
          </div>
          
          <!-- Newsletter Form -->
          <NewsletterFormWithHeaders />
        </div>
        
        
      </article>

      <!-- Author Picture Column -->
      <aside class="hidden lg:block">
        <div class="sticky top-8">
         
          
          <!-- Navigation Links -->
          <nav class="space-y-3">
           
          
            
            <!-- Divider -->
            <div class="border-t border-gray-200 dark:border-gray-700 my-4"></div>
            
          <div class="text-sm">
            <h3 class="font-medium text-gray-900 dark:text-gray-200 mb-3">Popular Posts</h3>
            <ul class="space-y-2">
              {(() => {
                // Get popular posts first, excluding certain tags
                const filteredPopularPosts = popularPosts.filter(p => 
                  !p.data.tags?.includes('books') &&
                  !p.data.tags?.includes('curiosities') &&
                  p.id !== post.id
                );
                
                // If we need more posts to reach 20, add random ones
                const postsToShow = [];
                postsToShow.push(...filteredPopularPosts);
                
                if (postsToShow.length < 20) {
                  const popularPostIds = new Set(filteredPopularPosts.map(p => p.id));
                  const additionalPosts = allPosts
                    .filter(p => 
                      !popularPostIds.has(p.id) && // Exclude posts already in popular list
                      p.id !== post.id && // Exclude current post
                      !p.data.tags?.includes('books') &&
                      !p.data.tags?.includes('curiosities')
                    )
                    .sort(() => Math.random() - 0.5)
                    .slice(0, 20 - postsToShow.length);
                  
                  postsToShow.push(...additionalPosts);
                }
                
                return postsToShow.slice(0, 20).map((postItem) => (
                  <li>
                    <a 
                      href={`/posts/${postItem.slug}`}
                      class="text-gray-600 dark:text-gray-400 hover:text-gray-800 dark:hover:text-gray-200 transition-colors duration-200 underline underline-offset-2 decoration-1 hover:decoration-2"
                    >
                      {postItem.data.title}
                    </a>
                  </li>
                ));
              })()}
            </ul>
             
            <!-- Divider -->
            <div class="border-t border-gray-200 dark:border-gray-700 my-4"></div>
          </div>
          </nav>
        </div>
      </aside>
    </div>
  </div>
 

 

</BaseLayout>

<style>
  /* Keep only essential styles */
  :global(.prose) {
    max-width: none;
    overflow-wrap: break-word;
    word-wrap: break-word;
    word-break: normal;
    hyphens: auto;
    font-size: 16px;
    line-height: 27px;
    font-family: 'Verdana', Geneva, sans-serif;
    font-weight: 400;
  }
  
  :global(.prose h1, .prose h2, .prose h3, .prose h4, .prose h5, .prose h6) {
    font-weight: 400;
    color: var(--text);
    overflow-wrap: break-word;
    word-wrap: break-word;
  }
  
  :global(.prose h1) {
    font-size: 1.5em;
    margin-top: 2em;
    margin-bottom: 1em;
    line-height: 1.5;
  }
  
  :global(.prose h2) {
    font-size: 1.3em;
    margin-top: 1.75em;
    margin-bottom: 0.75em;
  }
  
  :global(.prose h3) {
    font-size: 1.1em;
    margin-top: 1.5em;
    margin-bottom: 0.75em;
  }
  
  :global(.prose p) {
    color: var(--text);
    overflow-wrap: break-word;
    word-wrap: break-word;
    margin-bottom: 2.5em;
  }

  :global(.prose li) {
    color: var(--text);
    overflow-wrap: break-word;
    word-wrap: break-word;
    margin-bottom: 0.5em;
  }

  :global(.prose blockquote) {
    color: var(--text);
    border-left: 4px solid #e5e7eb;
    overflow-wrap: break-word;
    word-wrap: break-word;
    padding-right: 1rem;
  }

  :global(.prose a) {
    color: var(--text);
    text-decoration-line: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    overflow-wrap: break-word;
    word-wrap: break-word;
    word-break: break-word;
  }

  /* Code block styles with improved mobile handling */
  :global(.prose code) {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.8em;  /* Slightly smaller than surrounding text */
    font-weight: 400;   /* Lighter weight for better readability */
    color: #abb2bf;
    background-color: #282c34;
    padding: 0.2em 0.4em;
    border-radius: 0.25em;
    white-space: pre-wrap;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  :global(.prose pre) {
    background-color: #282c34;
    border-radius: 0.5em;
    margin: 1.5em 0;
    padding: 1em 0.5em 1em 0;
    position: relative;
    overflow-x: hidden;
    width: 100%;
    box-sizing: border-box;
  }

  /* Ensure code blocks within pre tags don't get the inline styling */
  :global(.prose pre code) {
    background-color: transparent;
    padding: 0 1em 0 2.5rem; /* Increased left padding for better readability */
    border-radius: 0;
    color: inherit;
    font-size: 0.875em;
    font-family: 'JetBrains Mono', 'Fira Code', 'Roboto Mono', monospace;
    display: block;
    white-space: pre-wrap;
    word-wrap: break-word;
    word-break: break-word;
    overflow-wrap: anywhere; /* Ensure long words can break */
    width: 100%;
    box-sizing: border-box;
  }

  /* Ensure prose content doesn't have width restrictions */
  :global(.prose) {
    max-width: none !important;
    overflow-x: hidden;
  }

  /* Ensure content doesn't overflow */
  article {
    width: 100%;
    overflow-x: hidden;
    box-sizing: border-box;
  }

  /* Make sure images stay within container */
  :global(.prose img) {
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  /* Make blockquotes responsive */
  :global(.quoteback) {
    max-width: 100%;
    overflow-wrap: break-word;
    word-wrap: break-word;
    box-sizing: border-box;
  }

  /* Table styles are now in global.css */

  /* Add responsive styles for related posts section */
  @media (max-width: 640px) {
    .grid-cols-[120px_1fr] {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    
    :global(.prose) {
      font-size: 15px;
      line-height: 24px;
    }
    
    :global(.prose p) {
      margin-bottom: 2.5em; /* Keep the same increased spacing on mobile */
    }
    
    :global(.prose li) {
      margin-bottom: 0.5em; /* Keep the reduced spacing for list items on mobile */
    }
    
    :global(.prose h1) {
      font-size: 1.3em;
      margin-top: 1.5em;
      margin-bottom: 0.8em;
      line-height: 1.4;
    }
    
    :global(.prose h2) {
      font-size: 1.1em;
      margin-top: 1.75em;
      margin-bottom: 0.75em;
    }
    
    :global(.prose h3) {
      font-size: 1em;
      margin-top: 1.5em;
      margin-bottom: 0.75em;
    }
    
    :global(.prose pre) {
      margin-left: -1.25rem;
      margin-right: -1.25rem;
      border-radius: 0;
      width: 100%;
      padding: 1em 0.5em 1em 0.5em;
      overflow-x: hidden;
    }
    
    :global(.prose pre code) {
      padding-left: 2rem; /* Increased left padding on mobile */
      font-size: 0.8em;
      overflow-x: hidden;
      white-space: pre-wrap;
      word-break: break-all;
      overflow-wrap: break-word;
    }
    
    :global(.prose blockquote) {
      margin-left: 0;
      margin-right: 0;
      padding-left: 1rem;
    }
    
    /* Adjust container padding on mobile */
    .max-w-4xl {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }
    
    /* Adjust link behavior on mobile */
    :global(.prose a) {
      word-break: break-word;
      display: inline-block; /* Helps with breaking long URLs */
      max-width: 100%;
    }
  }

  /* Dark mode overrides with higher specificity */
  :global(html.dark .prose h1),
  :global(html.dark .prose h2),
  :global(html.dark .prose h3),
  :global(html.dark .prose h4),
  :global(html.dark .prose h5),
  :global(html.dark .prose h6) {
    color: var(--text);
  }

  :global(html.dark .prose p),
  :global(html.dark .prose li) {
    color: var(--text);
  }

  :global(html.dark .prose blockquote) {
    color: #9ca3af;
    border-left-color: #374151;
  }

  :global(html.dark .prose strong) {
    color: var(--text);
  }

  :global(html.dark .prose a) {
    color: var(--text);
  }

  /* Copy button styles */
  :global(.copy-button) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #abb2bf;
    background-color: #353b45;
    border: 1px solid #454d5b;
    border-radius: 0.375rem;
    opacity: 0;
    transition: all 0.2s ease;
    cursor: pointer;
    width: 32px;
    height: 32px;
  }

  :global(.copy-button svg) {
    width: 16px;
    height: 16px;
    stroke-width: 2px;
  }

  :global(.prose pre:hover .copy-button) {
    opacity: 1;
  }

  :global(.copy-button:hover) {
    background-color: #454d5b;
    color: #ffffff;
    transform: scale(1.05);
  }

  :global(.copy-button:active) {
    transform: scale(0.95);
  }

  :global(.copy-button:focus) {
    outline: 2px solid #61afef;
    outline-offset: 2px;
  }

  /* Add a subtle line number effect */
  :global(.prose pre) {
    counter-reset: line;
  }
</style>

<script set:html={prismCopyButtonScript} /> 