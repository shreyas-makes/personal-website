---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import NewsletterFormWithHeaders from '../components/NewsletterFormWithHeaders.astro';
import { formatDate } from '../utils/formatDate';
import { calculateReadingTime } from '../utils/readingTime';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import GrowthStage from '../components/GrowthStage.astro';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const readingTime = calculateReadingTime(post.body);
const formattedDate = formatDate(post.data.date);

// Get related posts
const allPosts = await getCollection('posts', ({ id, data }) => !data.draft);
const relatedPosts = allPosts
  .filter(p => 
    p.id !== post.id && // Exclude current post
    !p.data.tags?.includes('books') && // Exclude books
    !p.data.tags?.includes('projects') && // Exclude projects
    !['about', 'now', 'vibes'].includes(p.slug) // Exclude specific pages
  )
  .sort(() => Math.random() - 0.5) // Randomize order
  .slice(0, 20); // Take 20 posts

// Add Prism.js copy button functionality
const prismCopyButtonScript = `
  document.addEventListener('DOMContentLoaded', (event) => {
    // Add copy button to code blocks
    document.querySelectorAll('pre').forEach((block) => {
      // Create button
      const button = document.createElement('button');
      button.className = 'copy-button';
      button.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>';
      button.setAttribute('aria-label', 'Copy code to clipboard');
      
      // Add button to code block
      block.style.position = 'relative';
      block.appendChild(button);
      
      // Add click handler
      button.addEventListener('click', async () => {
        const code = block.querySelector('code');
        const text = code.innerText;
        
        try {
          await navigator.clipboard.writeText(text);
          button.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg>';
          setTimeout(() => {
            button.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>';
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
          button.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 13h-1v-1h1v1zm0-3h-1V7h1v5z"></path></svg>';
        }
      });
    });
  });
`;

console.log("Post data in PostLayout:", post.data); // Debug log
console.log("Stage value in PostLayout:", post.data.stage); // Debug log
---

<BaseLayout title={`${post.data.title} | Shreyas`}>
  <article class="max-w-4xl mx-auto px-5 sm:px-6 py-6">
    {post.data.image && (
      <Image
        src={post.data.image}
        alt={post.data.title}
        width={1200}
        height={630}
        format="webp"
        loading="eager"
        class="rounded-lg mb-8"
      />
    )}
    
   
    
    <h1 class="text-xl sm:text-xl font-normal text-gray-900 dark:text-gray-200 mb-2">
      {post.data.title}
    </h1>
    
    <div class="mb-1 flex items-center space-x-2">
      {post.data.tags && post.data.tags.length > 0 && (
        <a 
          href={`/tags/${post.data.tags[0]}`} 
          class="text-xs text-gray-500 dark:text-gray-400 hover:text-gray-800 dark:hover:text-gray-200 font-['Verdana',_Geneva,_sans-serif]"
        >
          {post.data.tags[0]} </a>
      )}
      <span class="text-xs text-gray-500 dark:text-gray-400">— {readingTime} — {formattedDate}
      </span>
    </div>
    
    {/* Add debug info */}
    <!-- {JSON.stringify(post.data)} -->
    
    {/* Ensure stage is being passed correctly */}
    <GrowthStage stage={post.data.stage || 'seedling'} />
    
    <div class="mt-2 prose prose-neutral dark:prose-invert max-w-none">
      <slot />
    </div>
  </article>

  <!-- Newsletter Form -->
  <NewsletterFormWithHeaders />

  <!-- Related Posts Section -->
  <section class="max-w-4xl mx-auto px-5 sm:px-6 mb-12">
    <h2 class="text-xl sm:text-xl font-normal text-gray-800 dark:text-gray-300 mb-8">Here are some other posts you might enjoy</h2>
    <div class="space-y-8">
      {relatedPosts.map((relatedPost) => {
        // Get first three lines as excerpt
        const lines = relatedPost.body.split('\n').slice(0,3);
        const excerpt = lines.join('\n') + '...';
        
        return (
          <div class="flex flex-col">
            <a href={`/posts/${relatedPost.slug}`} 
               class="text-gray-800 dark:text-gray-200 hover:text-gray-600 dark:hover:text-gray-400 text-base sm:text-lg font-normal underline underline-offset-4 decoration-1 mb-2">
              {relatedPost.data.title}
            </a>
            <p class="text-gray-600 dark:text-gray-300 text-sm sm:text-base mb-3 line-clamp-2">
              {excerpt}
            </p>
            <span class="text-gray-500 dark:text-gray-400 text-xs sm:text-sm">
              {relatedPost.data.tags && relatedPost.data.tags.length > 0 ? relatedPost.data.tags[0] : 'post'}
            </span>
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  /* Keep only essential styles */
  :global(.prose) {
    max-width: none;
    overflow-wrap: break-word;
    word-wrap: break-word;
    word-break: normal;
    hyphens: auto;
    font-size: 16px;
    line-height: 27px;
    font-family: 'Verdana', Geneva, sans-serif;
    font-weight: 400;
  }
  
  :global(.prose h1, .prose h2, .prose h3, .prose h4, .prose h5, .prose h6) {
    font-weight: 400;
    color: var(--text);
    overflow-wrap: break-word;
    word-wrap: break-word;
  }
  
  :global(.prose h2) {
    font-size: 1.3em;
    margin-top: 1.75em;
    margin-bottom: 0.75em;
  }
  
  :global(.prose h3) {
    font-size: 1.1em;
    margin-top: 1.5em;
    margin-bottom: 0.75em;
  }
  
  :global(.prose p, .prose li) {
    color: var(--text);
    overflow-wrap: break-word;
    word-wrap: break-word;
  }

  :global(.prose blockquote) {
    color: var(--text);
    border-left: 4px solid #e5e7eb;
    overflow-wrap: break-word;
    word-wrap: break-word;
    padding-right: 1rem;
  }

  :global(.prose a) {
    color: var(--text);
    text-decoration-line: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    overflow-wrap: break-word;
    word-wrap: break-word;
    word-break: break-word;
  }

  /* Code block styles with improved mobile handling */
  :global(.prose code) {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.8em;  /* Slightly smaller than surrounding text */
    font-weight: 400;   /* Lighter weight for better readability */
    color: #abb2bf;
    background-color: #282c34;
    padding: 0.2em 0.4em;
    border-radius: 0.25em;
    white-space: pre-wrap;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  :global(.prose pre) {
    background-color: #282c34;
    border-radius: 0.5em;
    margin: 1.5em 0;
    padding: 1em 0.5em 1em 0;
    position: relative;
    overflow-x: auto;
    width: 100%;
    box-sizing: border-box;
    max-width: 100vw;
  }

  /* Ensure code blocks within pre tags don't get the inline styling */
  :global(.prose pre code) {
    background-color: transparent;
    padding: 0 1em 0 1.5rem; /* Reduced left padding for mobile */
    border-radius: 0;
    color: inherit;
    font-size: 0.875em;
    font-family: 'JetBrains Mono', 'Fira Code', 'Roboto Mono', monospace;
    display: block;
    white-space: pre-wrap;
    word-wrap: break-word;
    overflow-wrap: anywhere; /* Ensure long words can break */
    width: 100%;
    box-sizing: border-box;
  }

  /* Ensure prose content doesn't have width restrictions */
  :global(.prose) {
    max-width: none !important;
    overflow-x: hidden;
  }

  /* Ensure content doesn't overflow */
  article {
    width: 100%;
    overflow-x: hidden;
    box-sizing: border-box;
  }

  /* Make sure images stay within container */
  :global(.prose img) {
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  /* Make blockquotes responsive */
  :global(.quoteback) {
    max-width: 100%;
    overflow-wrap: break-word;
    word-wrap: break-word;
    box-sizing: border-box;
  }

  /* Ensure tables don't overflow */
  :global(.prose table) {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    white-space: nowrap;
    box-sizing: border-box;
  }

  /* Add responsive styles for related posts section */
  @media (max-width: 640px) {
    .grid-cols-[120px_1fr] {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    
    :global(.prose) {
      font-size: 15px;
      line-height: 24px;
    }
    
    :global(.prose p) {
      margin-bottom: 1.25em;
    }
    
    :global(.prose h2) {
      font-size: 1.1em;
      margin-top: 1.75em;
      margin-bottom: 0.75em;
    }
    
    :global(.prose h3) {
      font-size: 1em;
      margin-top: 1.5em;
      margin-bottom: 0.75em;
    }
    
    :global(.prose pre) {
      margin-left: -1.25rem;
      margin-right: -1.25rem;
      border-radius: 0;
      width: calc(100% + 2.5rem);
      padding: 1em 0.5em 1em 0.5em;
      overflow-x: auto;
    }
    
    :global(.prose pre code) {
      padding-left: 1rem;
      font-size: 0.8em;
      overflow-x: auto;
      white-space: pre-wrap;
    }
    
    :global(.prose blockquote) {
      margin-left: 0;
      margin-right: 0;
      padding-left: 1rem;
    }
    
    /* Adjust article padding on mobile */
    article.max-w-4xl {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }
    
    /* Adjust link behavior on mobile */
    :global(.prose a) {
      word-break: break-word;
      display: inline-block; /* Helps with breaking long URLs */
      max-width: 100%;
    }
  }

  /* Dark mode overrides with higher specificity */
  :global(html.dark .prose h1),
  :global(html.dark .prose h2),
  :global(html.dark .prose h3),
  :global(html.dark .prose h4),
  :global(html.dark .prose h5),
  :global(html.dark .prose h6) {
    color: var(--text);
  }

  :global(html.dark .prose p),
  :global(html.dark .prose li) {
    color: var(--text);
  }

  :global(html.dark .prose blockquote) {
    color: #9ca3af;
    border-left-color: #374151;
  }

  :global(html.dark .prose strong) {
    color: var(--text);
  }

  :global(html.dark .prose a) {
    color: var(--text);
  }

  /* Copy button styles */
  :global(.copy-button) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #abb2bf;
    background-color: #353b45;
    border: 1px solid #454d5b;
    border-radius: 0.375rem;
    opacity: 0;
    transition: all 0.2s ease;
    cursor: pointer;
    width: 32px;
    height: 32px;
  }

  :global(.copy-button svg) {
    width: 16px;
    height: 16px;
    stroke-width: 2px;
  }

  :global(.prose pre:hover .copy-button) {
    opacity: 1;
  }

  :global(.copy-button:hover) {
    background-color: #454d5b;
    color: #ffffff;
    transform: scale(1.05);
  }

  :global(.copy-button:active) {
    transform: scale(0.95);
  }

  :global(.copy-button:focus) {
    outline: 2px solid #61afef;
    outline-offset: 2px;
  }

  /* Add a subtle line number effect */
  :global(.prose pre) {
    counter-reset: line;
  }
</style>

<script set:html={prismCopyButtonScript} /> 