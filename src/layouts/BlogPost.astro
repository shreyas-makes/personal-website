---
import BaseLayout from './BaseLayout.astro';
import NewsletterFormWithHeaders from '../components/NewsletterFormWithHeaders.astro';
import KeepReadingFeed from '../components/KeepReadingFeed.astro';
import Upvoter from '../components/Upvoter.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { calculateReadingTime } from '../utils/readingTime';
import { generateExcerpt } from '../utils/excerptUtils';

type Props = CollectionEntry<'posts'>['data'] & {
  slug?: string;
  body?: string;
};

const {
  title,
  date,
  publishDate,
  updatedDate,
  heroImage,
  tags,
  stage = 'seedling',
  slug,
  body,
  description,
  summary
} = Astro.props;

const readingTime = body ? calculateReadingTime(body) : null;
const articleDate = publishDate ?? date ?? updatedDate ?? null;
const authorAvatar = 'https://0.gravatar.com/avatar/991d6680b622c30f9c9e06b25ab884e4e6a18dd35deac1a61f7c9464e1a6d1c3?size=256';
const authorName = 'Shreyas Prakash';
const shareUrl = `${Astro.site}${slug}/`;
const shareTitle = title ?? 'Post';
const shareLinkedIn = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`;
const shareTwitter = `https://twitter.com/intent/tweet?url=${encodeURIComponent(shareUrl)}&text=${encodeURIComponent(shareTitle)}`;
const shareEmail = `mailto:?subject=${encodeURIComponent(shareTitle)}&body=${encodeURIComponent(shareUrl)}`;

// Generate OG image URL for this post
const ogImageUrl = `${Astro.site}og/${slug}.png`;

// Post description - prefer frontmatter, then summary, then excerpt
const postDescription =
  description ||
  summary ||
  (body ? generateExcerpt(body) : '') ||
  (readingTime
    ? `${title} - ${readingTime} on Shreyas Prakash's blog`
    : `${title} - A new post on Shreyas Prakash's blog`);

const allPosts = await getCollection('posts', ({ data, id }) => !data.draft && !id.startsWith('booknotes/'));

const normalizedSlug = (slug ?? '').toLowerCase();
const normalizedTags = (tags ?? []).map((tag) => tag.toLowerCase());
const excludedKudosTags = new Set(['books', 'book-notes', 'projects', 'curiosities', 'prototypes']);
const specialNonPostSlugs = new Set(['about', 'now', 'vibes']);
const canReceiveKudos =
  Boolean(slug) &&
  !specialNonPostSlugs.has(normalizedSlug) &&
  !normalizedTags.some((tag) => excludedKudosTags.has(tag));
---

<BaseLayout 
  title={`${title} | Shreyas`}
  description={postDescription}
  ogImage={ogImageUrl}
  ogType="article"
  showMainFooterSection={true}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-8 sm:pt-16 pb-16">
    <article class="max-w-4xl mx-auto">
      <header class="mb-16 text-center">
        <h1 class="text-3xl sm:text-4xl font-semibold text-gray-900 dark:text-gray-100 leading-tight">
          {title}
        </h1>

        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:items-center sm:justify-center sm:gap-6">
          <div class="flex-shrink-0">
            <img
              src={authorAvatar}
              alt={`${authorName} headshot`}
              width="80"
              height="80"
              class="w-16 h-16 sm:w-20 sm:h-20 rounded-full border-2 border-gray-900 dark:border-gray-100 object-cover"
            />
          </div>

          <div class="flex flex-col items-center gap-3 text-gray-900 dark:text-gray-100 sm:items-start">
            <p class="text-lg font-semibold">{authorName}</p>
          </div>
        </div>
      </header>
      
      <div class="prose prose-neutral dark:prose-invert max-w-none">
        <slot />
      </div>

      <div class="post-divider" role="separator" aria-label="Post divider">
        <span class="post-divider__line" aria-hidden="true"></span>
        <span class="post-divider__label">End of post</span>
        <span class="post-divider__line" aria-hidden="true"></span>
      </div>

      {canReceiveKudos && slug && (
        <div class="mb-8">
          <Upvoter slug={slug} />
        </div>
      )}

      <div class="flex justify-center">
        <div class="flex items-center gap-3 text-gray-500 dark:text-gray-300">
          <a
            href={shareLinkedIn}
            class="p-2 rounded-full border border-transparent hover:border-gray-300 dark:hover:border-gray-600 transition-colors"
            aria-label="Share on LinkedIn"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19 0H5C2.24 0 0 2.24 0 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5V5c0-2.76-2.24-5-5-5zm-9 18H7v-7h3v7zm-1.5-8.29c-.97 0-1.75-.79-1.75-1.76s.78-1.76 1.75-1.76c.96 0 1.75.79 1.75 1.76s-.77 1.76-1.75 1.76zm11.5 8.29h-3v-3.61c0-.86-.02-1.97-1.2-1.97-1.2 0-1.38.94-1.38 1.91V18h-3v-7h2.88v.96h.04c.4-.75 1.36-1.55 2.8-1.55 2.99 0 3.55 1.97 3.55 4.52V18z" />
            </svg>
          </a>
          <a
            href={shareTwitter}
            class="p-2 rounded-full border border-transparent hover:border-gray-300 dark:hover:border-gray-600 transition-colors"
            aria-label="Share on Twitter"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.633 7.997c.013.176.013.353.013.53 0 5.39-4.103 11.603-11.603 11.603-2.305 0-4.45-.676-6.25-1.843.322.038.63.051.965.051 1.905 0 3.66-.647 5.056-1.742-1.781-.038-3.28-1.21-3.797-2.823.253.038.506.063.772.063.367 0 .734-.051 1.076-.139-1.868-.38-3.268-2.022-3.268-3.999v-.051c.546.304 1.19.492 1.868.517a4.06 4.06 0 0 1-1.81-3.385c0-.746.19-1.43.534-2.027a11.646 11.646 0 0 0 8.45 4.287 4.588 4.588 0 0 1-.101-.93c0-2.233 1.81-4.056 4.056-4.056 1.166 0 2.22.492 2.961 1.29a8.074 8.074 0 0 0 2.574-.983 4.027 4.027 0 0 1-1.78 2.244 8.17 8.17 0 0 0 2.342-.63 8.71 8.71 0 0 1-2.04 2.09z" />
            </svg>
          </a>
          <a
            href={shareEmail}
            class="p-2 rounded-full border border-transparent hover:border-gray-300 dark:hover:border-gray-600 transition-colors"
            aria-label="Share via email"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
              <path d="M3 5h18a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              <path d="m3 7 9 6 9-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>

      {/* Newsletter Section */}
      <div class="mt-16">
        <NewsletterFormWithHeaders />
      </div>

      <KeepReadingFeed posts={allPosts} />
    </article>
  </div>
</BaseLayout>

<style>
  :global(.prose) {
    font-size: 16px;
    line-height: 1.7;
    font-family: 'Verdana', Geneva, sans-serif;
    font-weight: 400;
  }
  
  :global(.prose img) {
    max-width: 100%;
    height: auto;
    margin: 2rem auto;
    border-radius: 8px;
    display: block;
  }
  
  :global(.prose h1, .prose h2, .prose h3, .prose h4, .prose h5, .prose h6) {
    font-weight: 400;
    font-family: 'Verdana', Geneva, sans-serif;
  }
  
  :global(.prose p) {
    margin-bottom: 1.5em;
  }
  
  /* Mobile adjustments */
  @media (max-width: 640px) {
    :global(.prose) {
      font-size: 15px;
      line-height: 1.6;
    }
  }

  .post-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 3.75rem 0 3.25rem;
    color: #111827;
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }

  .post-divider__line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, #d1d5db, transparent);
  }

  .post-divider__label {
    white-space: nowrap;
  }

  :global(.dark) .post-divider {
    color: #9ca3af;
  }

  :global(.dark) .post-divider__line {
    background: linear-gradient(90deg, transparent, #374151, transparent);
  }
</style> 
