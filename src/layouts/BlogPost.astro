---
import BaseLayout from './BaseLayout.astro';
import NewsletterFormWithHeaders from '../components/NewsletterFormWithHeaders.astro';
import type { CollectionEntry } from 'astro:content';
import GrowthStage from '../components/GrowthStage.astro';
import { formatDate } from '../utils/formatDate';
import { calculateReadingTime } from '../utils/readingTime';

type Props = CollectionEntry<'posts'>['data'] & {
  slug?: string;
  body?: string;
};

const { title, date, publishDate, updatedDate, heroImage, tags, stage = 'seedling', slug, body } = Astro.props;

// Calculate reading time if body is provided
const readingTime = body ? calculateReadingTime(body) : null;

// Generate OG image URL for this post
const ogImageUrl = `${Astro.site}og/${slug}.svg`;

// Post description - could come from frontmatter or generated
const postDescription = `${title} - ${readingTime} read on Shreyas Prakash's blog`;

// Debug logging for BlogPost props
console.log('BlogPost Debug - Data:');
console.log('- title:', title);
console.log('- slug:', slug);
console.log('- ogImageUrl:', ogImageUrl);
console.log('- postDescription:', postDescription);
console.log('- readingTime:', readingTime);
---

<BaseLayout 
  title={`${title} | Shreyas`}
  description={postDescription}
  ogImage={ogImageUrl}
  ogType="article"
  showMainFooterSection={true}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-12 sm:pt-24 pb-6">
    <article class="max-w-3xl mx-auto">
      <header class="mb-12 text-center">
        {/* Author Image */}
        <div class="flex justify-center mb-6">
          <img 
            src="https://0.gravatar.com/avatar/991d6680b622c30f9c9e06b25ab884e4e6a18dd35deac1a61f7c9464e1a6d1c3?size=256"
            alt="Shreyas Prakash"
            class="w-16 h-16 rounded-full object-cover border-2 border-black dark:border-white"
          />
        </div>
        
        {/* Title */}
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 dark:text-gray-100 leading-tight mb-6">
          {title}
        </h1>
        
        {/* Metadata - Only reading time */}
        {readingTime && (
          <div class="flex justify-center items-center text-xs text-gray-500 dark:text-gray-400">
            <div class="flex items-center gap-1 px-2 py-1 bg-gray-50 dark:bg-gray-800/50 rounded-full">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{readingTime}</span>
            </div>
          </div>
        )}
      </header>
      
      <div class="prose prose-neutral dark:prose-invert max-w-none">
        <slot />
      </div>
      
      {/* Newsletter Section */}
      <div class="mt-16">
        <NewsletterFormWithHeaders />
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  :global(.prose) {
    font-size: 16px;
    line-height: 1.7;
    font-family: 'Verdana', Geneva, sans-serif;
    font-weight: 400;
  }
  
  :global(.prose img) {
    max-width: 100%;
    height: auto;
    margin: 2rem auto;
    border-radius: 8px;
    display: block;
  }
  
  :global(.prose h1, .prose h2, .prose h3, .prose h4, .prose h5, .prose h6) {
    font-weight: 400;
    font-family: 'Verdana', Geneva, sans-serif;
  }
  
  :global(.prose p) {
    margin-bottom: 1.5em;
  }
  
  /* Mobile adjustments */
  @media (max-width: 640px) {
    :global(.prose) {
      font-size: 15px;
      line-height: 1.6;
    }
  }
</style> 

