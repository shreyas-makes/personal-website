---
export interface Props {
  title?: string;
}

const { title = "" } = Astro.props;
---

<figure class="mermaid-wrapper">
  {title && <figcaption>{title}</figcaption>}
  <div class="mermaid">
    <slot />
  </div>
</figure>

<script>
  import 'https://cdn.jsdelivr.net/npm/mermaid@10.6.1/dist/mermaid.min.js';

  document.addEventListener('DOMContentLoaded', () => {
    // Initialize mermaid with configuration
    (window as any).mermaid.initialize({
      startOnLoad: true,
      theme: 'default',
      flowchart: {
        htmlLabels: true,
        useMaxWidth: false
      },
      er: {
        useMaxWidth: false
      },
      sequence: {
        useMaxWidth: false,
        noteFontWeight: '14px',
        actorFontSize: '14px',
        messageFontSize: '16px'
      },
      journey: {
        useMaxWidth: false
      },
      gitGraph: {
        useMaxWidth: false
      }
    });
  });

  // Re-render diagrams on page transitions
  document.addEventListener('astro:page-load', () => {
    try {
      (window as any).mermaid.init(undefined, document.querySelectorAll('.mermaid'));
    } catch (error) {
      console.error('Error initializing mermaid diagrams:', error);
    }
  });
</script>

<style>
  .mermaid-wrapper {
    margin: 2rem 0;
    overflow-x: auto;
  }

  figcaption {
    text-align: center;
    font-style: italic;
    margin-bottom: 0.5rem;
  }

  .mermaid {
    text-align: center;
  }
</style> 
