---
---

<div class="mt-6 mb-12 max-w-3xl mx-auto px-4">
  <div class="text-center mb-6">
    <p class="text-sm text-gray-600 dark:text-gray-400">
      Subscribe to get future posts via email (or <a href="/rss.xml" class="underline underline-offset-2 hover:text-gray-900 dark:hover:text-gray-100">grab the RSS feed</a>). 2-3 ideas every month across design and tech
    </p>
  </div>

  <form 
    action="https://app.kit.com/forms/7662069/subscriptions"
    method="post" 
    class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
  >
    <label for="email-address" class="sr-only">Email address</label>
    <input 
      id="email-address" 
      name="email_address" 
      type="email" 
      autocomplete="email" 
      required 
      class="flex-1 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm text-gray-900 dark:text-gray-100 placeholder:text-gray-500 dark:placeholder:text-gray-400 focus:border-gray-400 dark:focus:border-gray-500 focus:outline-none focus:ring-2 focus:ring-gray-400 dark:focus:ring-gray-500 transition-all duration-200"
      placeholder="Enter your email"
    />
    <button 
      type="submit" 
      class="sm:flex-shrink-0 rounded-lg bg-gray-900 dark:bg-gray-800 px-4 py-2.5 text-sm font-medium text-white hover:bg-gray-800 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900 transition-all duration-200"
    >
      Subscribe
    </button>
  </form>
</div>

<script async src="https://f.convertkit.com/ckjs/ck.5.js"></script>