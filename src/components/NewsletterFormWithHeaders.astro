---
---

<div class="mt-6 mb-12 max-w-3xl mx-auto px-4">
  <div class="text-center mb-6">
    <p class="text-lg sm:text-xl text-gray-600 leading-relaxed">
      Subscribe to get future posts via email (or <a href="/rss.xml" class="underline underline-offset-2 hover:text-gray-900 ">grab the RSS feed</a>). 2-3 ideas every month across design and tech
    </p>
  </div>

  <form 
    action="https://app.kit.com/forms/7662069/subscriptions"
    method="post" 
    class="flex flex-col sm:flex-row gap-4 max-w-3xl mx-auto"
  >
    <label for="email-address" class="sr-only">Email address</label>
    <input 
      id="email-address" 
      name="email_address" 
      type="email" 
      autocomplete="email" 
      required 
      class="flex-1 rounded-xl border border-gray-300 bg-white px-5 py-3 text-xl text-gray-900 placeholder:text-gray-500 focus:border-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-400 transition-all duration-200"
      placeholder="Enter your email"
    />
    <button 
      type="submit" 
      class="sm:flex-shrink-0 rounded-xl bg-[#374151] px-7 py-3 text-xl font-medium text-white hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-all duration-200"
    >
      Subscribe
    </button>
  </form>
</div>

<script async src="https://f.convertkit.com/ckjs/ck.5.js"></script>
