---
import { getCollection } from 'astro:content';

// Get all posts including drafts
const allPosts = await getCollection('posts');

// Calculate stats
const posts = allPosts.filter(post => !post.data.draft);

// Calculate total words (assuming each post has a body)
const totalWords = posts.reduce((acc, post) => {
  const wordCount = post.body.split(/\s+/).length;
  return acc + wordCount;
}, 0);

// Format numbers with commas
const formatNumber = (num: number) => num.toLocaleString();

// Get current year for copyright
const currentYear = new Date().getFullYear();
---

<footer class="bg-white dark:bg-[#161618] text-gray-900 dark:text-gray-100">
  <div class="max-w-6xl mx-auto px-4 py-6 md:py-12 relative">
    <!-- Bottom footer section with stats and links -->
    <div class="border-t border-gray-300 dark:border-gray-700 pt-6 md:pt-8">
      <div class="text-sm text-gray-600 dark:text-gray-300 space-y-4">
        <!-- Site statistics -->
        <div class="mb-4 md:mb-6 max-w-3xl mx-auto">
          <p class="mb-4 text-center leading-relaxed">
            This digital garden contains {formatNumber(totalWords)} words written.
          </p>
        </div>
        
        <div class="text-center">
          <a href="https://twitter.com/shreyasprakash" class="hover:text-gray-800 dark:hover:text-gray-100 mx-2 md:mx-4 underline underline-offset-4 decoration-[0.1em]">Twitter</a>
          <a href="https://linkedin.com/in/shreyasprakash" class="hover:text-gray-800 dark:hover:text-gray-100 mx-2 md:mx-4 underline underline-offset-4 decoration-[0.1em]">LinkedIn</a>
          <a href="https://youtube.com/@shreyasprakash" class="hover:text-gray-800 dark:hover:text-gray-100 mx-2 md:mx-4 underline underline-offset-4 decoration-[0.1em]">YouTube</a>
        </div>

        <div class="max-w-3xl mx-auto">
          <p class="mb-4 text-center leading-relaxed">
            This website is built in a way the internet was meant to be. This means a simple, content-first website, sharing thoughts and knowledge for free.
          </p>
        </div>
        
        <div class="text-center">
          <p>©{currentYear} Shreyas Prakash</p>
        </div>
      </div>
    </div>

    <!-- Back to top button -->
    <div class="flex justify-center mt-6 md:mt-8">
      <a href="#top" class="inline-block border-2 border-gray-300/50 dark:border-gray-700/50 rounded-full p-3 md:p-4 hover:border-gray-400 dark:hover:border-gray-600 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8 text-gray-600 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7" />
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: auto;
  }
</style> 

  