---
import { getCollection } from 'astro:content';

// Get all posts including drafts
const allPosts = await getCollection('posts');

// Calculate stats
const posts = allPosts.filter(post => !post.data.draft);

// Calculate total words (assuming each post has a body)
const totalWords = posts.reduce((acc, post) => {
  const wordCount = post.body ? post.body.split(/\s+/).length : 0;
  return acc + wordCount;
}, 0);

const canonicalBaseUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://shreyasprakash.com';
const currentPath = Astro.url?.pathname || '/';
const canonicalPageUrl = `${canonicalBaseUrl}${currentPath}`;
const pageLabel = currentPath === '/'
  ? 'homepage'
  : currentPath
      .split('/')
      .filter(Boolean)
      .pop()
      ?.replace(/-/g, ' ') || 'this page';

const prompt = `I am reading "${pageLabel}" by Shreyas Prakash (${canonicalPageUrl}). Help me go deeper on his ideas around modern software, design, product thinking, and AI. Please give: (1) a concise summary, (2) key mental models, (3) related essays from shreyasprakash.com to read next, and (4) practical takeaways I can apply this week.`;
const encodedPrompt = encodeURIComponent(prompt);
const llmLinks = [
  {
    name: 'Gemini',
    href: `https://gemini.google.com/app?q=${encodedPrompt}`,
    icon: 'https://cdn.jsdelivr.net/npm/simple-icons@16.9.0/icons/googlegemini.svg',
    iconType: 'img'
  },
  {
    name: 'Perplexity',
    href: `https://www.perplexity.ai/search?q=${encodedPrompt}`,
    icon: 'https://cdn.jsdelivr.net/npm/simple-icons@16.9.0/icons/perplexity.svg',
    iconType: 'img'
  },
  {
    name: 'ChatGPT',
    href: `https://chatgpt.com/?q=${encodedPrompt}`,
    iconType: 'openai'
  },
  {
    name: 'Claude',
    href: `https://claude.ai/new?q=${encodedPrompt}`,
    icon: 'https://cdn.jsdelivr.net/npm/simple-icons@16.9.0/icons/claude.svg',
    iconType: 'img'
  }
];

// Format numbers with commas
const formatNumber = (num: number) => num.toLocaleString();

// Get current year for copyright
const currentYear = new Date().getFullYear();
---

<footer class="bg-white dark:bg-[#161618] text-gray-900 dark:text-gray-100">
  <div class="max-w-6xl mx-auto px-4 py-6 md:py-12 relative">
    <!-- Bottom footer section with stats and links -->
    <div class="border-t border-gray-300 dark:border-gray-700 pt-6 md:pt-8">
      <div class="text-base md:text-lg text-gray-600 dark:text-gray-300 space-y-5">
        <!-- Site statistics -->
        <div class="mb-6 md:mb-8 max-w-3xl mx-auto">
          <p class="mb-6 text-center leading-relaxed">
            This digital garden contains {formatNumber(totalWords)} words written.
          </p>
        </div>
        
        <div class="text-center text-lg md:text-xl">
          <a href="https://github.com/shreyas-makes" class="hover:text-gray-800 dark:hover:text-gray-100 mx-2 md:mx-4 underline underline-offset-4 decoration-[0.1em]">GitHub</a>
          <a href="https://linkedin.com/in/shreyasprakash" class="hover:text-gray-800 dark:hover:text-gray-100 mx-2 md:mx-4 underline underline-offset-4 decoration-[0.1em]">LinkedIn</a>
          <a href="https://youtube.com/@shreyasprakash" class="hover:text-gray-800 dark:hover:text-gray-100 mx-2 md:mx-4 underline underline-offset-4 decoration-[0.1em]">YouTube</a>
        </div>

        <div class="max-w-3xl mx-auto">
          <p class="mb-4 text-center leading-relaxed">
            This website is built in a way the internet was meant to be. This means a simple, content-first website, sharing thoughts and knowledge for free.
          </p>
        </div>

        <div class="max-w-3xl mx-auto">
          <p class="text-xs uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400 text-center mb-4">Ask an AI</p>
          <div class="flex items-center justify-center gap-6 sm:gap-8">
            {llmLinks.map((item) => (
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex h-10 w-10 items-center justify-center text-gray-700 transition-opacity hover:opacity-70 dark:text-gray-200"
                aria-label={`Open in ${item.name}`}
                title={item.name}
              >
                {item.iconType === 'openai' ? (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" class="h-7 w-7 fill-current" aria-hidden="true">
                    <path d="M14.949 6.547a3.94 3.94 0 0 0-.348-3.273 4.11 4.11 0 0 0-4.4-1.934A4.1 4.1 0 0 0 8.423.2 4.15 4.15 0 0 0 6.305.086a4.1 4.1 0 0 0-1.891.948 4.04 4.04 0 0 0-1.158 1.753 4.1 4.1 0 0 0-1.563.679A4 4 0 0 0 .554 4.72a3.99 3.99 0 0 0 .502 4.731 3.94 3.94 0 0 0 .346 3.274 4.11 4.11 0 0 0 4.402 1.933c.382.425.852.764 1.377.995.526.231 1.095.35 1.67.346 1.78.002 3.358-1.132 3.901-2.804a4.1 4.1 0 0 0 1.563-.68 4 4 0 0 0 1.14-1.253 3.99 3.99 0 0 0-.506-4.716m-6.097 8.406a3.05 3.05 0 0 1-1.945-.694l.096-.054 3.23-1.838a.53.53 0 0 0 .265-.455v-4.49l1.366.778q.02.011.025.035v3.722c-.003 1.653-1.361 2.992-3.037 2.996m-6.53-2.75a2.95 2.95 0 0 1-.36-2.01l.095.057L5.29 12.09a.53.53 0 0 0 .527 0l3.949-2.246v1.555a.05.05 0 0 1-.022.041L6.473 13.3c-1.454.826-3.311.335-4.15-1.098m-.85-6.94A3.02 3.02 0 0 1 3.07 3.949v3.785a.51.51 0 0 0 .262.451l3.93 2.237-1.366.779a.05.05 0 0 1-.048 0L2.585 9.342a2.98 2.98 0 0 1-1.113-4.094zm11.216 2.571L8.747 5.576l1.362-.776a.05.05 0 0 1 .048 0l3.265 1.86a3 3 0 0 1 1.173 1.207 2.96 2.96 0 0 1-.27 3.2 3.05 3.05 0 0 1-1.36.997V8.279a.52.52 0 0 0-.276-.445m1.36-2.015-.097-.057-3.226-1.855a.53.53 0 0 0-.53 0L6.249 6.153V4.598a.04.04 0 0 1 .019-.04L9.533 2.7a3.07 3.07 0 0 1 3.257.139c.474.325.843.778 1.066 1.303.223.526.289 1.103.191 1.664zM5.503 8.575 4.139 7.8a.05.05 0 0 1-.026-.037V4.049c0-.57.166-1.127.476-1.607s.752-.864 1.275-1.105a3.08 3.08 0 0 1 3.234.41l-.096.054-3.23 1.838a.53.53 0 0 0-.265.455zm.742-1.577 1.758-1 1.762 1v2l-1.755 1-1.762-1z"/>
                  </svg>
                ) : (
                  <img
                    src={item.icon}
                    alt={`${item.name} icon`}
                    width="28"
                    height="28"
                    loading="lazy"
                    class="h-7 w-7 dark:invert"
                  />
                )}
              </a>
            ))}
          </div>
        </div>

        <!-- Back to top button -->
        <div class="flex justify-center mt-6 md:mt-8">
          <a href="#top" class="inline-block border-2 border-gray-300/50 dark:border-gray-700/50 rounded-full p-3 md:p-4 hover:border-gray-400 dark:hover:border-gray-600 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8 text-gray-600 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7" />
            </svg>
          </a>
        </div>

        <div class="text-center text-lg md:text-xl pt-2">
          <p>©{currentYear} Shreyas Prakash</p>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: auto;
  }
</style> 

  
