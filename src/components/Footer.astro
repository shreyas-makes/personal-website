---
import { getCollection } from 'astro:content';

// Get all posts including drafts
const allPosts = await getCollection('posts');

// Calculate stats
const posts = allPosts.filter(post => !post.data.draft);
const projects = posts.filter(post => post.data.tags?.includes('projects'));
const books = posts.filter(post => post.data.tags?.includes('books'));
const prototypes = posts.filter(post => post.data.tags?.includes('prototypes'));

// Calculate total words (assuming each post has a body)
const totalWords = posts.reduce((acc, post) => {
  const wordCount = post.body.split(/\s+/).length;
  return acc + wordCount;
}, 0);

// Format numbers with commas
const formatNumber = (num: number) => num.toLocaleString();
---

<footer class="max-w-3xl mx-auto px-4 py-12 text-center">
  <div class="border-t border-gray-200/30 dark:border-gray-800/30 pt-8">
    <div class="text-sm text-gray-500 dark:text-gray-400 space-y-4">
      <div class="mb-4">
        <p class="mb-4">
          This digital garden contains 
          <a href="/posts" class="hover:text-gray-700 dark:hover:text-gray-300 underline underline-offset-4 decoration-[0.1em]">{posts.length} essays and notes</a>, 
          <a href="/tags/projects" class="hover:text-gray-700 dark:hover:text-gray-300 underline underline-offset-4 decoration-[0.1em]">{projects.length} projects</a>, 
          <a href="/tags/prototypes" class="hover:text-gray-700 dark:hover:text-gray-300 underline underline-offset-4 decoration-[0.1em]">{prototypes.length} prototypes</a>, 
          <a href="/tags/books" class="hover:text-gray-700 dark:hover:text-gray-300 underline underline-offset-4 decoration-[0.1em]">{books.length} book reviews</a> 
          and {formatNumber(totalWords)} words.
        </p>
        

      </div>
      <div class="flex items-center justify-center my-6">
        <div class="w-full max-w-xs mx-auto border-t border-gray-200/30 dark:border-gray-800/30 border-[1px]"></div>
      </div>
      <div>
        <a href="https://twitter.com/shreyasprakash" class="hover:text-gray-700 dark:hover:text-gray-300 mx-4">Twitter</a>
        <a href="https://linkedin.com/in/shreyasprakash" class="hover:text-gray-700 dark:hover:text-gray-300 mx-4">LinkedIn</a>
        <a href="https://youtube.com/@shreyasprakash" class="hover:text-gray-700 dark:hover:text-gray-300 mx-4">YouTube</a>
        </div>
          <p class="mb-4 max-w-3xl">
            This website is built in a way the internet was meant to be. This means a simple, content-first website, sharing thoughts and knowledge for free.
          </p>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: auto;
  }
</style> 

  