---
import type { PhilosopherInfluence } from '../utils/philosopherUtils';

interface Props {
  influences: PhilosopherInfluence[];
}

const { influences = [] } = Astro.props as Props;
---

<section class="my-12">
  <h2 class="text-xl font-medium text-gray-600 dark:text-gray-400 mb-4">Influenced by</h2>
  {influences.length === 0 ? (
    <p class="text-gray-600 dark:text-gray-400 text-sm">
      I’ll keep writing about the thinkers who continue to shape my work.
    </p>
  ) : (
    <div class="flex flex-wrap items-center text-gray-800 dark:text-gray-200 leading-relaxed gap-y-2" style="word-break: break-word;">
      {influences.map((influence, index) => (
        <span class="flex items-start gap-2 mr-4" key={influence.slug}>
          {index > 0 && <span class="text-gray-400 dark:text-gray-600" aria-hidden="true">•</span>}
          <span class="inline-flex items-start gap-1 pb-1">
            <a
              href={`/influences/${influence.slug}`}
              class="underline hover:no-underline text-gray-800 dark:text-gray-200 hover:text-gray-600 dark:hover:text-gray-400"
              style="text-decoration-skip-ink: auto; text-underline-position: under;"
            >
              {influence.name}
            </a>
            <sup class="text-xs text-gray-500 dark:text-gray-400 align-super">{influence.count}</sup>
          </span>
        </span>
      ))}
    </div>
  )}
</section>
