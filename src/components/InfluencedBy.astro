---
import type { PhilosopherInfluence } from '../utils/philosopherUtils';

interface Props {
  influences: PhilosopherInfluence[];
}

const { influences = [] } = Astro.props as Props;

const getNotchHeight = (count: number) => {
  const capped = Math.min(count, 12);
  return Math.round(8 + capped * 0.9);
};
---

<section class="my-12">
  <h2 class="text-xl font-medium text-gray-600 dark:text-gray-400 mb-4">Influenced by</h2>
  {influences.length === 0 ? (
    <p class="text-gray-600 dark:text-gray-400 text-sm">
      I’ll keep writing about the thinkers who continue to shape my work.
    </p>
  ) : (
    <div class="baseline-ticker-shell text-gray-800 dark:text-gray-200">
      <ul class="baseline-ticker-track" role="list">
        {influences.map((influence) => (
          <li
            class="baseline-ticker-item"
            style={`--notch-height: ${getNotchHeight(influence.count)}px;`}
            key={influence.slug}
          >
            <span class="baseline-ticker-notch" aria-hidden="true">
              <span class="baseline-ticker-value">{influence.count}</span>
              <span class="baseline-ticker-stem" />
            </span>
            <a
              href={`/influences/${influence.slug}`}
              class="baseline-ticker-name hover:text-gray-600 dark:hover:text-gray-400"
            >
              {influence.name}
            </a>
            <span class="sr-only">{`${influence.name} referenced ${influence.count} times`}</span>
          </li>
        ))}
      </ul>
    </div>
  )}
</section>

<style>
  .baseline-ticker-shell {
    position: relative;
    overflow-x: auto;
    padding-bottom: 1.5rem;
    scrollbar-width: none;
  }

  .baseline-ticker-shell::-webkit-scrollbar {
    display: none;
  }

  .baseline-ticker-track {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    align-items: flex-end;
    list-style: none;
    margin: 0;
    padding: 0 0 0.75rem;
  }

  .baseline-ticker-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    min-width: max-content;
    font-size: 0.95rem;
  }

  .baseline-ticker-name {
    display: inline-block;
    padding-bottom: 0.35rem;
    font-weight: 500;
    transition: color 120ms ease;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-decoration-skip-ink: auto;
    text-underline-offset: 0.2em;
  }

  .baseline-ticker-notch {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(107, 114, 128, 0.9);
  }

  :global(.dark) .baseline-ticker-notch {
    color: rgba(156, 163, 175, 0.85);
  }

  .baseline-ticker-value {
    font-variant-numeric: tabular-nums;
  }

  .baseline-ticker-stem {
    width: 1px;
    height: var(--notch-height, 12px);
    background: rgba(55, 65, 81, 0.35);
    background: color-mix(in srgb, currentColor 35%, transparent);
  }

  @media (max-width: 640px) {
    .baseline-ticker-track {
      flex-wrap: nowrap;
      gap: 0.5rem 1.5rem;
      padding-right: 1rem;
    }

    .baseline-ticker-item {
      font-size: 0.9rem;
    }
  }
</style>
