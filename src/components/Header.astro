---
import { getCollection } from 'astro:content';
import SearchButton from './SearchButton';
import Search from './Search';
// Commenting out this import until we create the file
// import ThemeToggle from './ThemeToggle.astro';

// Get all posts for search
const posts = await getCollection('posts', ({ data }) => !data.draft);

// Get the specific posts for nav links
const [nowPost, vibesPost] = await Promise.all([
  getCollection('posts', ({ data }) => data.slug === 'now'),
  getCollection('posts', ({ data }) => data.slug === 'vibes')
]);

const nowSlug = nowPost[0]?.slug;
const vibesSlug = vibesPost[0]?.slug;

// Get current path but make it reactive to navigation
let pathname = new URL(Astro.request.url).pathname;
let currentPath = pathname.slice(1);

// Check if we're on the homepage
const isHomepage = pathname === '/';
---



  <header 
    id="main-header"
    class="fixed top-0 left-0 right-0 z-50 bg-white dark:bg-gray-800 pb-2 sm:pb-4 border-b border-gray-200 dark:border-gray-600 transition-transform duration-300 ease-in-out translate-y-0"
    transition:persist="header"
    transition:animate="none"
  >
  <!-- Add preload hints for critical pages -->
  <link rel="preload" href="/" as="document" />
  <link rel="preload" href="/books" as="document" />
  <link rel="preload" href="/tags/prototypes" as="document" />
  
  <div class="max-w-4xl mt-2 sm:mt-4 mx-auto px-4 sm:px-6">
    <!-- Desktop layout - unified header -->
    <div class="hidden md:flex md:items-center md:justify-between">
      <!-- Logo/Home link - left aligned -->
      <a href="/" class="text-xl font-normal text-gray-900 dark:text-white hover:text-gray-700 dark:hover:text-gray-300" aria-label="Home" data-astro-prefetch>Shreyas Prakash</a>
      
      <!-- Unified navigation - center -->
      <nav class="flex gap-6 text-sm" id="desktop-navigation">
        <!-- Now Tab -->
        <a 
          href={`/posts/${nowSlug}`}
          class:list={[
            "flex items-center gap-2 transition-colors",
            currentPath === `posts/${nowSlug}` 
              ? "nav-item-active" 
              : "nav-item"
          ]}
          data-path={`posts/${nowSlug}`}
          data-astro-prefetch="hover"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Now</span>
        </a>
        
        <!-- Feed Tab -->
        <a 
          href="/feed"
          class:list={[
            "flex items-center gap-2 transition-colors",
            currentPath === "feed" 
              ? "nav-item-active" 
              : "nav-item"
          ]}
          data-path="feed"
          data-astro-prefetch="hover"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
          </svg>
          <span>Feed</span>
        </a>
        
        <!-- Books Tab -->
        <a 
          href="/books"
          class:list={[
            "flex items-center gap-2 transition-colors",
            currentPath === "books" 
              ? "nav-item-active" 
              : "nav-item"
          ]}
          data-path="books"
          data-astro-prefetch="hover"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          <span>Books</span>
        </a>
        
        <!-- Lists Tab -->
        <a 
          href="/lists"
          class:list={[
            "flex items-center gap-2 transition-colors",
            currentPath === "lists" 
              ? "nav-item-active" 
              : "nav-item"
          ]}
          data-path="lists"
          data-astro-prefetch="hover"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
          <span>Lists</span>
        </a>
        
       
      </nav>
      
      <!-- Desktop utility icons - right aligned -->
      <div class="flex items-center gap-3">
        <SearchButton client:load />
        <button id="theme-toggle-desktop" class="p-1 text-gray-500 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-200">
          <svg class="w-5 h-5 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
