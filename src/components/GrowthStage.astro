---
export interface Props {
  stage: 'seedling' | 'sprout' | 'plant';
}

const { stage } = Astro.props;

const stageInfo = {
  seedling: {
    icon: '🌱',
    name: 'Seedling'
  },
  sprout: {
    icon: '🌿',
    name: 'Sprout'
  },
  plant: {
    icon: '🪴',
    name: 'Plant'
  }
};

const { icon, name } = stageInfo[stage];
console.log("Rendering GrowthStage with stage:", stage); // Add debug log
---

<div class="growth-stage inline-flex items-center gap-1.5 text-sm text-gray-600 mt-2 mb-6 px-2.5 py-1 border border-[#e5e1d8] rounded-full">
  <span class="text-base leading-none">{icon}</span>
  <span class="leading-none">{name}</span>
</div>

<style>
  .growth-stage {
    font-style: italic;
    background-color: rgba(245, 242, 235, 0.5);
  }
</style>
