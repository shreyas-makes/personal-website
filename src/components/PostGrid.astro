---
const { posts } = Astro.props;

// Add validation helper
const getSafeTitle = (post) => {
  if (!post.data) return 'Untitled Post';
  return post.data.title?.trim() || 'Untitled Post';
};

const getSafeDate = (post) => {
  try {
    if (!post.data?.date) return 'No date available';
    const date = new Date(post.data.date);
    return isNaN(date) ? 'Invalid date' : date.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    });
  } catch {
    return 'Invalid date';
  }
};
---

<div class="post-grid">
  {posts.map(post => (
    <article class="post-card">
      <a href={`${import.meta.env.BASE_URL}posts/${post.data.slug}`}>
        <div class="post-content">
          <h2 class="text-base sm:text-lg font-normal text-gray-900 dark:text-gray-200">{getSafeTitle(post)}</h2>
          <time datetime={post.data.date || ''} class="text-xs text-gray-500 dark:text-gray-400">
            {getSafeDate(post)}
          </time>
          {post.data.tags.length > 0 && (
            <div class="tags">
              {post.data.tags.map(tag => (
                <span class="tag text-xs">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </a>
    </article>
  ))}
</div>

<style>
  .post-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }

  .post-card {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.2s;
    padding: 1.5rem;
  }

  .post-card:hover {
    transform: translateY(-4px);
  }

  .post-content {
    padding: 1.5rem;
    font-size: 15px;
    line-height: 1.5;
  }

  .post-content h2 {
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .post-content time {
    display: block;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .tags {
    margin-top: 1rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    background: #f3f4f6;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
  }

  /* Dark mode adjustments */
  :global(.dark) .post-card {
    border-color: #2d3748;
  }

  :global(.dark) .tag {
    background: #2d3748;
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .post-content {
      font-size: 14px;
      padding: 1.25rem;
    }
  }
</style> 