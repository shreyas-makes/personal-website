import { generateExcerpt } from '../utils/excerptUtils';

const { post } = Astro.props;
const readingTime = calculateReadingTime(post.body);
const excerpt = generateExcerpt(post.body);

<article class="group">
  <a href={`/posts/${post.slug}`} class="block space-y-1">
    <h3 class="text-base sm:text-lg font-normal text-gray-900 dark:text-gray-100 group-hover:text-gray-600 dark:group-hover:text-gray-400">
      {post.data.title}
    </h3>
    <div class="text-gray-600 dark:text-gray-400 text-xs sm:text-sm">
      {formatDate(post.data.date)} · {readingTime}
    </div>
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed text-xs sm:text-sm">
      {excerpt}
    </p>
  </a>
</article> 