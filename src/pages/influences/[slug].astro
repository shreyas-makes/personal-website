---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { calculateReadingTime } from '../../utils/readingTime';
import { generateExcerpt } from '../../utils/excerptUtils';
import { getInfluenceStats, getPhilosopherMentions } from '../../utils/philosopherUtils';
import { PHILOSOPHERS } from '../../data/philosophers';

export const prerender = true;

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const published = allPosts.filter((post) => !post.data.draft);
  const influences = getInfluenceStats(published, PHILOSOPHERS.length);

  return influences.map(({ slug }) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error('Missing influence slug');
}

const allPosts = await getCollection('posts');
const publishedPosts = allPosts.filter((post) => !post.data.draft);

const { philosopher, mentions } = getPhilosopherMentions(publishedPosts, slug);

if (!philosopher) {
  throw new Error(`No philosopher configured for slug "${slug}"`);
}

const getPostUrl = (slug: string) =>
  slug.startsWith('booknotes/')
    ? `/books/${slug.replace('booknotes/', '')}`
    : `/${slug}`;

const mentionDetails = mentions.map(({ post, count }) => ({
  post,
  count,
  readingTime: calculateReadingTime(post.body),
  excerpt: post.data.summary || generateExcerpt(post.body),
  url: getPostUrl(post.slug),
}));

const formatDate = (date: string | Date) =>
  new Date(date).toLocaleDateString('en-GB', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  }).replace(/ /g, ' ');

const totalMentions = mentions.reduce((acc, mention) => acc + mention.count, 0);
---

<BaseLayout title={`Influenced by ${philosopher.name}`}>
  <main class="max-w-4xl mx-auto px-4 sm:px-5 pt-8 sm:pt-12 pb-8 sm:pb-10 text-gray-800 dark:text-gray-200">
    <div class="flex items-baseline justify-between mb-8">
      <div>
        <p class="text-xs tracking-[0.4em] uppercase text-gray-500 dark:text-gray-500">Influence</p>
        <h1 class="text-3xl font-normal text-gray-900 dark:text-gray-100 mt-3">{philosopher.name}</h1>
      </div>
      <span class="text-sm text-gray-500 dark:text-gray-400">
        {totalMentions} {totalMentions === 1 ? 'mention' : 'mentions'}
      </span>
    </div>

    {mentionDetails.length === 0 ? (
      <p class="text-gray-600 dark:text-gray-400">
        I haven’t written about {philosopher.name} yet—check back soon.
      </p>
    ) : (
      <ul class="space-y-8">
        {mentionDetails.map(({ post, count, readingTime, excerpt, url }) => (
          <li class="flex flex-col gap-1">
            <div class="flex flex-col space-y-1">
              <a
                href={url}
                class="text-gray-800 dark:text-gray-200 hover:text-gray-600 dark:hover:text-gray-400 block underline underline-offset-4 decoration-1"
              >
                <span class="block text-ellipsis overflow-hidden">
                  {post.data.title}
                </span>
              </a>
              <span class="text-gray-500 dark:text-gray-400 text-xs">
                {readingTime} <span class="mx-2"> — </span> {formatDate(post.data.date)}
              </span>
              <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                {excerpt}
              </p>
            </div>
            <p class="text-[11px] uppercase tracking-wide text-gray-500 dark:text-gray-500 mt-2">
              {count} {count === 1 ? 'mention' : 'mentions'} in this piece
            </p>
          </li>
        ))}
      </ul>
    )}

    <div class="mt-16">
      <a
        href="/"
        class="text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-gray-300 dark:decoration-gray-700"
      >
        ← Back to home
      </a>
    </div>
  </main>
</BaseLayout>
