---
import { ViewTransitions } from 'astro:transitions';
import { getCollection, getEntry } from 'astro:content';
import BlogPost from '../layouts/BlogPost.astro';

// Change to prerender = true to avoid server adapter requirement
export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data, id }) => {
    // Exclude all booknotes entries
    return !data.draft && !id.startsWith('booknotes/');
  });
  
  return posts
    .filter(post => !post.slug.includes('/')) // Exclude any posts with nested paths
    .map(post => ({
      params: { slug: post.slug },
      props: { post }
    }));
}

const { slug } = Astro.params;

// Handle missing slug first
if (!slug) {
  return Astro.redirect('/404');
}

const post = await getEntry('posts', slug);

// Then check if post exists
if (!post) {
  return Astro.redirect('/404');
}

const { Content } = await post.render();
---

<BlogPost {...post.data} slug={post.slug} body={post.body}>
  <ViewTransitions />
  <Content />
</BlogPost> 