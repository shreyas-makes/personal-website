---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ViewTransitions } from 'astro:transitions';

export const prerender = true;

const openSourceProjects = [
  {
    emoji: '💬',
    name: 'candor-teams',
    description: 'Public feedback board for transparent teams.',
    url: 'https://github.com/shreyas-makes/candor-teams',
    category: "Vision built"
  },
  {
    emoji: '✍️',
    name: 'signify-app',
    description: 'Writing platform to share 100% human-verified content.',
    url: 'https://github.com/shreyas-makes/signify-app',
    category: "Vision built"
  },
  {
    emoji: '🎬',
    name: 'mmmmh',
    description: 'Make YouTube videos snappier by removing silences and filler speech.',
    url: 'https://github.com/shreyas-makes/mmmmh',
    category: "Vision built"
  },
  {
    emoji: '🧼',
    name: 'deslopify',
    description: 'Make AI writing sound more humane.',
    url: 'https://github.com/shreyas-makes/deslopify',
    category: 'LLM workflow'
  },
  {
    emoji: '🖼️',
    name: 'asciify',
    description: 'Generate ASCII-first visual output workflows.',
    url: 'https://github.com/shreyas-makes/asciify',
    category: 'LLM workflow'
  },
  {
    emoji: '🔎',
    name: 'semantic-search',
    description: 'Do fully local semantic search over your Obsidian vault.',
    url: 'https://github.com/shreyas-makes/semantic-search',
    category: 'LLM workflow'
  },
  {
    emoji: '🧰',
    name: 'codex-skills',
    description: 'Personal library of reusable Codex skills and workflows.',
    url: 'https://github.com/shreyas-makes/codex-skills',
    category: 'LLM workflow'
  },
  {
    emoji: '📐',
    name: 'polygonfit',
    description: 'Rhino plugin for eliminating topology errors in polygons.',
    url: 'https://github.com/shreyas-makes/polygonfit',
    category: 'N=1 tool'
  },
  {
    emoji: '😵',
    name: 'kaomoji-generator',
    description: 'Quickly export kaomojis for instant messaging.',
    url: 'https://github.com/shreyas-makes/kaomoji-generator',
    category: 'N=1 tool'
  },
  {
    emoji: '♟️',
    name: 'chesscoach',
    description: 'AI chess coach for improving gameplay strategy.',
    url: 'https://github.com/shreyas-makes/chesscoach',
    category: 'N=1 tool'
  },
  {
    emoji: '🧩',
    name: 'twitter-to-trello',
    description: 'Convert Twitter bookmarks into Trello TODO items.',
    url: 'https://github.com/shreyas-makes/twitter-to-trello',
    category: 'N=1 tool'
  },
  {
    emoji: '☁️',
    name: 'xp-clouds',
    description: 'Playful cloud wallpaper experience for the web.',
    url: 'https://github.com/shreyas-makes/xp-clouds',
    category: 'N=1 tool'
  },
  {
    emoji: '👻',
    name: 'astro-blog-ghost',
    description: 'Personal website on Astro.',
    url: 'https://github.com/shreyas-makes/astro-blog-ghost',
    category: 'N=1 tool'
  },
  {
    emoji: '🧱',
    name: 'dftree',
    description: 'Generate a visual unicode file tree for any directory.',
    url: 'https://github.com/shreyas-makes/dftree',
    category: 'N=1 tool'
  },
  {
    emoji: '🧾',
    name: 'git-commit-summarizer',
    description: 'Summarize codebase updates from git commits.',
    url: 'https://github.com/shreyas-makes/git-commit-summarizer',
    category: 'N=1 tool'
  },
  {
    emoji: '🌐',
    name: 'simple-wiki-converter',
    description: 'Convert Wikipedia URLs into clean, reference-free text.',
    url: 'https://github.com/shreyas-makes/simple-wiki-converter',
    category: 'N=1 tool'
  },
  {
    emoji: '☎️',
    name: 'papercup-ai',
    description: 'Make internet calls to international phone numbers.',
    url: 'https://github.com/shreyas-makes/papercup-ai',
    category: "Vision built"
  }
];
---

<BaseLayout title="Work - Shreyas" showMainFooterSection={false}>
  <ViewTransitions client:only />
  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-2 sm:py-4">
    <section class="mt-2 sm:mt-12 md:mt-20 mb-12 max-w-4xl">
      <div class="text-gray-800 leading-relaxed space-y-4">
        <h1 class="text-3xl sm:text-4xl font-medium text-gray-900 mb-8">Work</h1>
        <p>I've built digital products used by millions of people across India and South East Asia. Previously worked across femtech, healthtech and edutech domains for the past decade, now in scientific publishing.</p>
      </div>
    </section>

    <!-- Notable Work Experiences -->
    <section class="mb-16">
      <h2 class="text-2xl sm:text-3xl font-medium text-gray-800 mb-6">Notable experiences</h2>
      
      <div class="space-y-6">
        <div class="experience-item">
          <h3 class="text-xl sm:text-2xl font-medium text-gray-900 mb-1">Springer Nature</h3>
          <p class="text-base sm:text-lg text-gray-600 mb-2">Product Manager, Author Experience (2024-Present)</p>
          <p class="text-base sm:text-lg text-gray-700 leading-relaxed">
            Springer Nature is the second largest scientific publisher in the world, founded in 1842 with more than 500K+ articles and books published annually. As the Product Manager for the Author Experience team, I lead a team of 15+ focused on improving the author experience after their manuscript is accepted. My key responsibilities include creating better pathways for authors to get funding, increasing transparency around licensing and rights, as well as in building infrastructure to support article processing cost payments and so on.
          </p>
        </div>

        <div class="experience-item">
          <h3 class="text-xl sm:text-2xl font-medium text-gray-900 mb-1">Noora Health</h3>
          <p class="text-base sm:text-lg text-gray-600 mb-2">Lead Product Manager (2021-2024)</p>
          <p class="text-base sm:text-lg text-gray-700 leading-relaxed">
            At Noora Health, I led the end-to-end design and successful launch of the Remote Engagement Service (RES), a transformative digital companion app. As Lead Product Manager for RES, I drove product strategy and development to deliver engaging health support for millions of patients and caregivers across India, Bangladesh, and Indonesia. My role involved overseeing the product's vision, coordinating cross-functional teams, and ensuring the platform's scalability and relevance in culturally diverse settings.
          </p>
        </div>

        <div class="experience-item">
          <h3 class="text-xl sm:text-2xl font-medium text-gray-900 mb-1">Design Verse Labs</h3>
          <p class="text-base sm:text-lg text-gray-600 mb-2">Co-founder (2020-2021)</p>
          <p class="text-base sm:text-lg text-gray-700 leading-relaxed">
            Co-founder of Dverse Labs, an healthcare startup involved in preventing the spread of hospital-acquired infections. The IoT device has been instrumental in reducing the risk of infections for 100+ healthcare workers and 3000+ patients everyday across 5 hospitals in South India.
          </p>
        </div>

        <div class="experience-item">
          <h3 class="text-xl sm:text-2xl font-medium text-gray-900 mb-1">Lead by Design Foundation</h3>
          <p class="text-base sm:text-lg text-gray-600 mb-2">Founding Director (2017-2020)</p>
          <p class="text-base sm:text-lg text-gray-700 leading-relaxed">
            As a director of this educational non-profit, I helped rural children invent for social good. I led various in-person and digital mentorship programmes for rural children to build contextual solutions with technology. More than 2000+ students of age 8-15 drove 12+ social innovations in their communities.
          </p>
        </div>
      </div>
    </section>

    <!-- Add visual separator -->
    <div class="my-20 border-t border-gray-200 "></div>

    <!-- Open Source Projects -->
    <section class="mb-16">
      <h2 class="text-2xl sm:text-3xl font-medium text-gray-800 mb-2">Open source projects</h2>
      <div class="open-source-list mt-8">
        {openSourceProjects.map((project) => (
          <article class="open-source-item">
            <p class="open-source-description">
              <a href={project.url} aria-label={`Open ${project.name} on GitHub`}>
                {project.description}
              </a>
            </p>
            <h3 class="open-source-name">{project.name}</h3>
          </article>
        ))}
      </div>
    </section>

    <!-- Add visual separator -->
    <div class="my-20 border-t border-gray-200 "></div>

    <!-- Awards and Recognition -->
    <section class="mb-16">
      <h2 class="text-3xl sm:text-4xl font-medium text-gray-800 mb-8">Awards and recognitions</h2>
      <div class="space-y-4">
        <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
          <a href="https://adplist.org/certifications/160035" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">ADPlist mentorship award</a> — 1000+ mentorship minutes (2021)
        </div>
        <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
          <a href="https://ifdesign.com/en/winner-ranking/project/equarun/304328" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">iF Design Award – Project Equarun</a> (2020)
        </div>
        <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
          Advisory board panellist for Creative Arts and Education — <a href="https://hundred.org/en" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">Hundred innovations, Helsinki</a> (2021)
        </div>
        <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
          <a href="https://www.tudelft.nl/onderwijs/studievoorlichting/praktische-zaken/scholarships/justus-louise-van-effen-excellence-scholarships" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">Justus and Louise van Effen Excellence Scholarship</a> — TU Delft (2018)
        </div>
        <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
          <a href="https://www.mitacs.ca/our-programs/globalink-research-internship-students/" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">Mitacs Globalink Scholar</a> (2015)
        </div>
      </div>
    </section>

    <!-- Add visual separator -->
    <div class="my-20 border-t border-gray-200 "></div>

    <!-- Notable Media Mentions -->
    <section class="mb-16">
      <h2 class="text-3xl sm:text-4xl font-medium text-gray-800 mb-8">Notable media mentions</h2>
      
      <!-- Articles & Blog Posts -->
      <div class="mb-10">
        <h3 class="text-xl sm:text-2xl font-medium text-gray-700 mb-4">Articles & Blog Posts</h3>
        <div class="space-y-3">
          <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
            <a href="https://sive.rs/met/40" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">Derek Sivers blog post mention</a> on Shreyas Prakash profile
          </div>
          <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
            <a href="https://www.mitacs.ca/news/toronto-star-international-students-add-brainpower-to-research-projects/" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">International students add brainpower to research projects</a> — Toronto Star
          </div>
          <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
            <a href="https://www.digit.in/features/general/dverse-labs-makes-hospitals-safer-with-uvfy-their-smart-modular-sterilization-tech-60139.html" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">dVERSE Labs makes hospitals safer with UVFY</a> — Digit.in
          </div>
        </div>
      </div>

      <!-- Podcasts -->
      <div class="mb-10">
        <h3 class="text-xl sm:text-2xl font-medium text-gray-700 mb-4">Podcasts</h3>
        <div class="space-y-3">
          <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
            <a href="https://open.spotify.com/show/6XiyWZpCDYaLCREPa0ZhfX?si=ORSYAXOlQ32ax-Wwc_G6uQ" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">Shake up the world podcast</a> (8 episodes with futurists in impact tech, 2020)
          </div>
          <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
            <a href="https://open.spotify.com/episode/2UxJgG7CT5P13OGRZQN6zd" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">Paul Lecrone's Penguin Latte podcast episode</a>
          </div>
          <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
            <a href="https://open.spotify.com/episode/4Jtp6LHa648XcipSnnSPzH?si=rpmlyFZWQ2arZ0uEKohQ_A" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">Effective practises of design thinking</a> — The Untextbook Project
          </div>
          <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
            <a href="https://open.spotify.com/episode/2366jLCrMuPEA4a1GUEXmQ?si=2Bint0bARruBOgwJAjkxpQ" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">Design thinking and education</a> — Reinvent Podcast
          </div>
        </div>
      </div>

      <!-- Video Content -->
      <div>
        <h3 class="text-xl sm:text-2xl font-medium text-gray-700 mb-4">Video Content</h3>
        <div class="space-y-3">
          <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
            <a href="https://youtu.be/CizvI9rqn_k?si=3n9VYJDbmRn9xE_v" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">Building useful, usable and desirable products</a> — Seekwise
          </div>
          <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
            <a href="https://www.youtube.com/watch?v=PQXGC2hRapQ" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">Generative Art with AI</a> — YouTube session
          </div>
        </div>
      </div>
    </section>

    <!-- Add visual separator -->
    <div class="my-20 border-t border-gray-200 "></div>

    <!-- Teaching and Mentoring -->
    <section class="mb-16">
      <h2 class="text-3xl sm:text-4xl font-medium text-gray-800 mb-8">Teaching and mentoring</h2>
      <div class="space-y-4">
        <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
          <a href="https://adplist.org/mentors/shreyas" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">ADPlist award for mentorship hours</a>
        </div>
        <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
          Mentor and judge at <a href="https://www.buildschool.net/" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">Buildschool</a> and Buildcamps hackathons
        </div>
      </div>
    </section>

    <!-- Add visual separator -->
    <div class="my-20 border-t border-gray-200 "></div>

    <!-- Research and Publications -->
    <section class="mb-16">
      <h2 class="text-3xl sm:text-4xl font-medium text-gray-800 mb-8">Research and publications</h2>
      <div class="space-y-4">
        <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
          Persaud, S., Prakash, S., & Flipsen, B. (2021). Dialogue for design teams: A case study of generative conversations for dealing with diversity. In <em>DS 110: Proceedings of the 23rd International Conference on Engineering and Product Design Education (E&PDE 2021), VIA Design, VIA University in Herning, Denmark. 9th-10th September 2021</em>.
        </div>
        <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
          <a href="https://resolver.tudelft.nl/uuid:81155d92-38e7-4eaf-9782-ff442cd84477" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">Using soft robotics as a medium for gender accessible education of preschoolers</a>, TU Delft
        </div>
        <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
          Citation profile: <a href="https://scholar.google.com/citations?view_op=view_citation&hl=en&user=9jGv5FkAAAAJ&citation_for_view=9jGv5FkAAAAJ:u5HHmVD_uO8C" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">Google Scholar</a>
        </div>
      </div>
    </section>

    <!-- Add visual separator -->
    <div class="my-20 border-t border-gray-200 "></div>

    <!-- Books Published -->
    <section class="mb-16">
      <h2 class="text-3xl sm:text-4xl font-medium text-gray-800 mb-8">Books published</h2>
      <div class="text-base sm:text-lg text-gray-700 leading-relaxed">
        <a href="https://archive.org/details/ruraldesigntoolkit" class="font-semibold text-gray-900 hover:text-gray-700 underline underline-offset-4 decoration-1">Rural design toolkit</a> by Shreyas Prakash, Krishna Thiruvengadam
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .open-source-list {
    display: grid;
    grid-template-columns: 1fr;
  }

  .open-source-item {
    padding: var(--space-200) 0;
  }

  .open-source-item:first-child {
    padding-top: 0;
  }

  .open-source-name {
    color: var(--color-text-secondary);
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: var(--font-weight-body);
    line-height: 1.5;
    margin: var(--space-50) 0 0;
  }

  .open-source-description {
    color: var(--color-text-primary);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: var(--font-weight-body);
    line-height: 1.625;
    margin: 0;
  }

  .open-source-description a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .open-source-description a:hover,
  .open-source-description a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  @media (min-width: 640px) {
    .open-source-name {
      font-size: 1.125rem;
    }

    .open-source-description {
      font-size: 1.125rem;
    }
  }

</style>

<style>
  /* Clean, minimal styling */
  :root {
    --text-primary: #1f2937;
    --text-secondary: #666;
    --hover-color: #555;
  }

  main {
    color: var(--text-primary);
    font-size: var(--font-size-prose);
    line-height: var(--line-height-prose);
  }

  .experience-item {
    padding-bottom: 1.75rem;
    border-bottom: 1px solid rgb(229 231 235 / 0.75);
  }

  .experience-item:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .quest-card {
    position: relative;
    overflow: hidden;
    border-color: rgb(251 191 36 / 0.45);
    background: linear-gradient(to bottom, rgb(255 251 235 / 0.96), rgb(255 255 255 / 0.98));
  }

  .quest-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 4px;
    background: rgb(217 119 6);
    opacity: 0.85;
  }

  .quest-card:hover {
    border-color: rgb(217 119 6 / 0.7);
    box-shadow: 0 10px 24px -14px rgb(217 119 6 / 0.7);
    color: inherit;
  }

  .quest-card .quest-title {
    transition: color 0.2s ease;
  }

  .quest-card:hover .quest-title {
    color: rgb(180 83 9);
  }

  .quest-tag {
    background: rgb(254 243 199 / 0.95);
    color: rgb(146 64 14);
  }

  /* Only apply hover effects on larger screens */
  @media (min-width: 640px) {
    a:hover {
      color: var(--hover-color);
    }
  }

  ul {
    list-style: none;
    padding: 0;
  }

</style>
