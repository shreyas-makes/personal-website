---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ViewTransitions } from 'astro:transitions';

export const prerender = true;
---

<BaseLayout title="Work - Shreyas" showMainFooterSection={false}>
  <ViewTransitions client:only />
  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-2 sm:py-4">
    <section class="mt-2 sm:mt-12 md:mt-20 mb-12 max-w-4xl">
      <div class="text-gray-800 dark:text-gray-200 leading-relaxed space-y-4">
        <h1 class="text-2xl font-medium text-gray-900 dark:text-gray-100 mb-8">Work</h1>
        <p>I've built digital products used by millions of people across India and South East Asia. Previously worked across femtech, healthtech and edutech domains for the past decade, now in scientific publishing.</p>
      </div>
    </section>

    <!-- Notable Work Experiences -->
    <section class="mb-16">
      <h2 class="text-xl font-normal text-gray-600 dark:text-gray-400 mb-6">Notable experiences</h2>
      
      <div class="space-y-8">
        <div>
          <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">Springer Nature</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">Product Manager, Author Experience (2024-Present)</p>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            Springer Nature is the second largest scientific publisher in the world, founded in 1842 with more than 500K+ articles and books published annually. As the Product Manager for the Author Experience team, I lead a team of 15+ focused on improving the author experience after their manuscript is accepted. My key responsibilities include creating better pathways for authors to get funding, increasing transparency around licensing and rights, as well as in building infrastructure to support article processing cost payments and so on.
          </p>
        </div>

        <div>
          <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">Noora Health</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">Lead Product Manager (2021-2024)</p>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            At Noora Health, I led the end-to-end design and successful launch of the Remote Engagement Service (RES), a transformative digital companion app. As Lead Product Manager for RES, I drove product strategy and development to deliver engaging health support for millions of patients and caregivers across India, Bangladesh, and Indonesia. My role involved overseeing the product's vision, coordinating cross-functional teams, and ensuring the platform's scalability and relevance in culturally diverse settings.
          </p>
        </div>

        <div>
          <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">Design Verse Labs</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">Co-founder (2020-2021)</p>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            Co-founder of Dverse Labs, an healthcare startup involved in preventing the spread of hospital-acquired infections. The IoT device has been instrumental in reducing the risk of infections for 100+ healthcare workers and 3000+ patients everyday across 5 hospitals in South India.
          </p>
        </div>

        <div>
          <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">Lead by Design Foundation</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">Founding Director (2017-2020)</p>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            As a director of this educational non-profit, I helped rural children invent for social good. I led various in-person and digital mentorship programmes for rural children to build contextual solutions with technology. More than 2000+ students of age 8-15 drove 12+ social innovations in their communities.
          </p>
        </div>
      </div>
    </section>

    <!-- Add visual separator -->
    <div class="my-20 border-t border-gray-200 dark:border-gray-800"></div>

    <!-- Open Source Tools and Side Quests -->
    <section class="mb-16">
      <h2 class="text-xl font-normal text-gray-600 dark:text-gray-400 mb-2">Open source tools and other side quests</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">943+ contributions in github repositories this year (2025)</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        <div>
          <div class="text-base text-gray-700 dark:text-gray-300 mb-1">
            <a href="https://chesscoach-one.vercel.app/" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Chess Coach</a>
          </div>
          <div class="mt-2 text-sm text-gray-600 dark:text-gray-100">
            AI-powered chess improvement tool
          </div>
        </div>
        
        <div>
          <div class="text-base text-gray-700 dark:text-gray-300 mb-1">
            <a href="https://github.com/shreyas-makes/writing.humans" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">writing.humans</a>
          </div>
          <div class="mt-2 text-sm text-gray-600 dark:text-gray-100">
            AI writing assistant
          </div>
        </div>

        <div>
          <div class="text-base text-gray-700 dark:text-gray-300 mb-1">
            <a href="https://github.com/shreyas-makes/editnext-plugin" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Edit Next</a>
          </div>
          <div class="mt-2 text-sm text-gray-600 dark:text-gray-100">
            Obsidian plugin for draft prioritization
          </div>
        </div>

        <div>
          <div class="text-base text-gray-700 dark:text-gray-300 mb-1">
            <a href="https://www.producthunt.com/products/clarity-5/launches" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Clarity Notes</a>
          </div>
          <div class="mt-2 text-sm text-gray-600 dark:text-gray-100">
            Screen free Youtube note-taking
          </div>
        </div>

        <div>
          <div class="text-base text-gray-700 dark:text-gray-300 mb-1">
            <a href="https://github.com/shreyas-makes/dicto" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Dicto</a>
          </div>
          <div class="mt-2 text-sm text-gray-600 dark:text-gray-100">
            Open source transcriber for Mac
          </div>
        </div>
      </div>
    </section>

    <!-- Add visual separator -->
    <div class="my-20 border-t border-gray-200 dark:border-gray-800"></div>

    <!-- Awards and Recognition -->
    <section class="mb-16">
      <h2 class="text-xl font-normal text-gray-600 dark:text-gray-400 mb-6">Awards and recognitions</h2>
      <div class="space-y-4">
        <div class="text-gray-700 dark:text-gray-300">
          <a href="https://adplist.org/certifications/160035" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">ADPlist mentorship award</a> — 1000+ mentorship minutes (2021)
        </div>
        <div class="text-gray-700 dark:text-gray-300">
          <a href="https://ifdesign.com/en/winner-ranking/project/equarun/304328" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">iF Design Award – Project Equarun</a> (2020)
        </div>
        <div class="text-gray-700 dark:text-gray-300">
          Advisory board panellist for Creative Arts and Education — <a href="https://hundred.org/en" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Hundred innovations, Helsinki</a> (2021)
        </div>
        <div class="text-gray-700 dark:text-gray-300">
          <a href="https://www.tudelft.nl/onderwijs/studievoorlichting/praktische-zaken/scholarships/justus-louise-van-effen-excellence-scholarships" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Justus and Louise van Effen Excellence Scholarship</a> — TU Delft (2018)
        </div>
        <div class="text-gray-700 dark:text-gray-300">
          <a href="https://www.mitacs.ca/our-programs/globalink-research-internship-students/" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Mitacs Globalink Scholar</a> (2015)
        </div>
      </div>
    </section>

    <!-- Add visual separator -->
    <div class="my-20 border-t border-gray-200 dark:border-gray-800"></div>

    <!-- Notable Media Mentions -->
    <section class="mb-16">
      <h2 class="text-xl font-normal text-gray-600 dark:text-gray-400 mb-6">Notable media mentions</h2>
      
      <!-- Articles & Blog Posts -->
      <div class="mb-8">
        <h3 class="text-base font-medium text-gray-800 dark:text-gray-200 mb-4">Articles & Blog Posts</h3>
        <div class="space-y-3">
          <div class="text-gray-700 dark:text-gray-300">
            <a href="https://sive.rs/met/40" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Derek Sivers blog post mention</a> on Shreyas Prakash profile
          </div>
          <div class="text-gray-700 dark:text-gray-300">
            <a href="https://www.mitacs.ca/news/toronto-star-international-students-add-brainpower-to-research-projects/" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">International students add brainpower to research projects</a> — Toronto Star
          </div>
          <div class="text-gray-700 dark:text-gray-300">
            <a href="https://www.digit.in/features/general/dverse-labs-makes-hospitals-safer-with-uvfy-their-smart-modular-sterilization-tech-60139.html" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">dVERSE Labs makes hospitals safer with UVFY</a> — Digit.in
          </div>
        </div>
      </div>

      <!-- Podcasts -->
      <div class="mb-8">
        <h3 class="text-base font-medium text-gray-800 dark:text-gray-200 mb-4">Podcasts</h3>
        <div class="space-y-3">
          <div class="text-gray-700 dark:text-gray-300">
            <a href="https://open.spotify.com/show/6XiyWZpCDYaLCREPa0ZhfX?si=ORSYAXOlQ32ax-Wwc_G6uQ" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Shake up the world podcast</a> (8 episodes with futurists in impact tech, 2020)
          </div>
          <div class="text-gray-700 dark:text-gray-300">
            <a href="https://open.spotify.com/episode/2UxJgG7CT5P13OGRZQN6zd" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Paul Lecrone's Penguin Latte podcast episode</a>
          </div>
          <div class="text-gray-700 dark:text-gray-300">
            <a href="https://open.spotify.com/episode/4Jtp6LHa648XcipSnnSPzH?si=rpmlyFZWQ2arZ0uEKohQ_A" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Effective practises of design thinking</a> — The Untextbook Project
          </div>
          <div class="text-gray-700 dark:text-gray-300">
            <a href="https://open.spotify.com/episode/2366jLCrMuPEA4a1GUEXmQ?si=2Bint0bARruBOgwJAjkxpQ" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Design thinking and education</a> — Reinvent Podcast
          </div>
        </div>
      </div>

      <!-- Video Content -->
      <div>
        <h3 class="text-base font-medium text-gray-800 dark:text-gray-200 mb-4">Video Content</h3>
        <div class="space-y-3">
          <div class="text-gray-700 dark:text-gray-300">
            <a href="https://youtu.be/CizvI9rqn_k?si=3n9VYJDbmRn9xE_v" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Building useful, usable and desirable products</a> — Seekwise
          </div>
          <div class="text-gray-700 dark:text-gray-300">
            <a href="https://www.youtube.com/watch?v=PQXGC2hRapQ" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Generative Art with AI</a> — YouTube session
          </div>
        </div>
      </div>
    </section>

    <!-- Add visual separator -->
    <div class="my-20 border-t border-gray-200 dark:border-gray-800"></div>

    <!-- Teaching and Mentoring -->
    <section class="mb-16">
      <h2 class="text-xl font-normal text-gray-600 dark:text-gray-400 mb-6">Teaching and mentoring</h2>
      <div class="space-y-4">
        <div class="text-gray-700 dark:text-gray-300">
          <a href="https://adplist.org/mentors/shreyas" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">ADPlist award for mentorship hours</a>
        </div>
        <div class="text-gray-700 dark:text-gray-300">
          Mentor and judge at <a href="https://www.buildschool.net/" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Buildschool</a> and Buildcamps hackathons
        </div>
      </div>
    </section>

    <!-- Add visual separator -->
    <div class="my-20 border-t border-gray-200 dark:border-gray-800"></div>

    <!-- Research and Publications -->
    <section class="mb-16">
      <h2 class="text-xl font-normal text-gray-600 dark:text-gray-400 mb-6">Research and publications</h2>
      <div class="space-y-4">
        <div class="text-gray-700 dark:text-gray-300">
          Persaud, S., Prakash, S., & Flipsen, B. (2021). Dialogue for design teams: A case study of generative conversations for dealing with diversity. In <em>DS 110: Proceedings of the 23rd International Conference on Engineering and Product Design Education (E&PDE 2021), VIA Design, VIA University in Herning, Denmark. 9th-10th September 2021</em>.
        </div>
        <div class="text-gray-700 dark:text-gray-300">
          <a href="https://resolver.tudelft.nl/uuid:81155d92-38e7-4eaf-9782-ff442cd84477" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Using soft robotics as a medium for gender accessible education of preschoolers</a>, TU Delft
        </div>
        <div class="text-gray-700 dark:text-gray-300">
          Citation profile: <a href="https://scholar.google.com/citations?view_op=view_citation&hl=en&user=9jGv5FkAAAAJ&citation_for_view=9jGv5FkAAAAJ:u5HHmVD_uO8C" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Google Scholar</a>
        </div>
      </div>
    </section>

    <!-- Add visual separator -->
    <div class="my-20 border-t border-gray-200 dark:border-gray-800"></div>

    <!-- Books Published -->
    <section class="mb-16">
      <h2 class="text-xl font-normal text-gray-600 dark:text-gray-400 mb-6">Books published</h2>
      <div class="text-gray-700 dark:text-gray-300">
        <a href="https://archive.org/details/ruraldesigntoolkit" class="hover:text-gray-900 dark:hover:text-gray-100 underline underline-offset-4 decoration-1">Rural design toolkit</a> by Shreyas Prakash, Krishna Thiruvengadam
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  /* Clean, minimal styling */
  :root {
    --text-primary: #000;
    --text-secondary: #666;
    --hover-color: #555;
  }

  /* Use Verdana as the font */
  main {
    color: var(--text-primary);
    line-height: 1.4;
    font-family: 'Verdana', Geneva, sans-serif;
    font-size: 15px;
  }

  h1, h2, h3 {
    font-weight: 400;
    color: var(--text-primary);
    font-family: 'Verdana', Geneva, sans-serif;
  }

  /* Only apply hover effects on larger screens */
  @media (min-width: 640px) {
    a:hover {
      color: var(--hover-color);
    }
  }

  ul {
    list-style: none;
    padding: 0;
  }

  /* Dark mode support */
  @media (prefers-color-scheme: dark) {
    :root {
      --text-primary: #e1e1e1;
      --text-secondary: #a1a1a1;
      --hover-color: #fff;
    }
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    main {
      font-size: 14px;
    }
  }

</style>