---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ViewTransitions } from 'astro:transitions';
import { getCollection } from 'astro:content';
import { calculateReadingTime } from '../utils/readingTime';
import { generateExcerpt } from '../utils/excerptUtils';

export const prerender = true;

// Get all interview posts
const interviews = await getCollection('posts', ({ id }) => {
  return id.startsWith('interviews/');
}).then(posts => {
  // Filter out drafts and add metadata
  const filteredPosts = posts.filter(post => !post.data.draft);
  
  // Pre-compute reading time and excerpt for each post
  return filteredPosts.map(post => ({
    ...post,
    readingTime: calculateReadingTime(post.body),
    excerpt: post.data.summary || generateExcerpt(post.body)
  }));
});

// Sort interviews by date (newest first) 
interviews.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Group interviews by year
const interviewsByYear = interviews.reduce((acc, interview) => {
  const year = new Date(interview.data.date).getFullYear();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(interview);
  return acc;
}, {} as Record<number, typeof interviews>);

// Sort years in descending order
const sortedYears = Object.keys(interviewsByYear)
  .map(Number)
  .sort((a, b) => b - a);

// Function to extract interviewee name from title
const extractIntervieweeName = (title: string) => {
  // Remove "Future of" prefix and everything after "with"
  const withMatch = title.match(/with (.+)$/);
  return withMatch ? withMatch[1] : title;
};

// Function to format date for interviews
const formatInterviewDate = (date: string) => {
  return new Date(date).toLocaleDateString('en-US', {
    month: 'long'
  });
};
---

<BaseLayout title="Interviews - Shreyas" showMainFooterSection={false}>
  <ViewTransitions client:only />
  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-2 sm:py-4">
    <section class="mt-2 sm:mt-12 md:mt-20 mb-12 max-w-4xl">
      <div class="text-gray-800 leading-relaxed space-y-4">
        <h1 class="text-3xl sm:text-4xl font-medium text-gray-900 mb-8">Interviews</h1>
        <p>Through the power of the internet, it's never been more possible to find like-minded folks and ask them questions.</p>
      </div>
    </section>

    <section class="mb-16">
      {sortedYears.map(year => (
        <div class="mb-16">
          <h2 id={year.toString()} class="text-2xl sm:text-3xl font-normal text-gray-700 mb-8 border-b border-gray-200 pb-2">
            <a href={`#${year}`} class="hover:text-gray-600 ">
              {year}
            </a>
          </h2>
          <div class="space-y-8">
            {interviewsByYear[year].map(interview => (
              <div class="group">
                <div class="flex flex-col sm:flex-row sm:items-start gap-4">
                  <div class="flex-1">
                    <a 
                      href={`/${interview.slug}`} 
                      class="block group-hover:text-gray-600 "
                    >
                      <h3 class="text-xl sm:text-2xl font-normal text-gray-900 leading-tight mb-1 underline underline-offset-4 decoration-1">
                        {extractIntervieweeName(interview.data.title)}
                      </h3>
                      <p class="text-gray-600 text-lg leading-relaxed mb-3">
                        {interview.data.description || 'No description available'}
                      </p>
                      <div class="flex flex-wrap items-center gap-4 text-base text-gray-500 ">
                        <span class="flex items-center gap-1">
                          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                          </svg>
                          {interview.readingTime}
                        </span>
                       
                      </div>
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

    <!-- Add visual separator -->
    <div class="my-20 border-t border-gray-200 "></div>

    {interviews.length === 0 && (
      <div class="text-center py-12">
        <p class="text-gray-600 ">
          No interviews available yet. Check back soon!
        </p>
      </div>
    )}
  </main>
</BaseLayout>

<style>
  /* Clean, minimal styling */
  :root {
    --text-primary: #000;
    --text-secondary: #666;
    --hover-color: #555;
  }

  main {
    color: var(--text-primary);
    font-size: var(--font-size-prose);
    line-height: var(--line-height-prose);
  }

  h1, h2, h3 {
    font-weight: 400;
  }

  /* Smooth anchor scrolling */
  html {
    scroll-behavior: smooth;
  }

  /* Year anchor styling */
  h2 a {
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s ease;
  }

  h2 a:hover {
    border-bottom-color: currentColor;
  }

  /* Interview item hover effects */
  .group:hover h3 {
    transition: color 0.2s ease;
  }


  /* Only apply hover effects on larger screens */
  @media (min-width: 640px) {
    a:hover {
      color: var(--hover-color);
    }
  }

  ul {
    list-style: none;
    padding: 0;
  }

  /* Focus states for accessibility */
  a:focus {
    outline: 2px solid #3B82F6;
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
