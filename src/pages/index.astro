---
// Homepage equivalent of index.hbs
import { ViewTransitions } from 'astro:transitions';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import SimpleNewsletterForm from '../components/SimpleNewsletterForm.astro';
import { calculateReadingTime } from '../utils/readingTime';
import { generateExcerpt } from '../utils/excerptUtils';

// Add prerender option to fix the warning
export const prerender = true;

// Get all posts including drafts (for stats calculation)
const allPostsWithDrafts = await getCollection('posts');

// Get interview posts separately
const interviews = await getCollection('posts', ({ id }) => {
  return id.startsWith('interviews/');
}).then(posts => {
  const filteredPosts = posts.filter(post => !post.data.draft);
  return filteredPosts.map(post => ({
    ...post,
    readingTime: calculateReadingTime(post.body),
    excerpt: post.data.summary || generateExcerpt(post.body)
  }));
});

// Sort interviews by date (newest first)
interviews.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Calculate stats (same as NewsletterFormWithHeaders)
const allPostsForStats = allPostsWithDrafts.filter(post => !post.data.draft && !post.id.startsWith('interviews/'));
const projectsForStats = allPostsForStats.filter(post => post.data.tags?.includes('projects'));
const booksForStats = allPostsForStats.filter(post => post.data.tags?.includes('books'));

// Calculate total words
const totalWords = allPostsForStats.reduce((acc, post) => {
  const wordCount = post.body ? post.body.split(/\s+/).length : 0;
  return acc + wordCount;
}, 0);

// Format numbers with commas
const formatNumber = (num: number) => num.toLocaleString();

// Special pages to exclude from feed
const SPECIAL_PAGES = [
  'Vibes.md',
  'Now.md',
  'About.md'
];

// Optimize data fetching with a single collection call
const posts = await getCollection('posts').then(allPosts => {
  const filtered = allPosts.filter(post => !post.data.draft && !post.id.startsWith('interviews/'));
  
  // Pre-compute all data in a single pass
  return filtered.reduce((acc, post) => {
    // Pre-compute reading time and excerpt
    const readingTime = calculateReadingTime(post.body);
    const excerpt = post.data.summary || generateExcerpt(post.body);

    const tags = post.data.tags || [];
    const isSpecialPage = SPECIAL_PAGES.includes(post.id) || 
                         ['about', 'now', 'vibes'].includes(post.slug);

    if (!isSpecialPage) {
      // Check for projects first as it's a priority category
      if (tags.includes('projects')) {
        acc.projects.push({...post, readingTime, excerpt});
      }
      // Check for other categories (can be multiple)
      else if (tags.includes('rough-notes')) {
        acc.roughNotes.push({...post, readingTime, excerpt});
      }
      else if (tags.includes('books')) {
        acc.books.push({...post, readingTime, excerpt});
      }
      else if (tags.includes('curiosities')) {
        // Ensure URL is explicitly included
        acc.curiosities.push({
          ...post, 
          readingTime, 
          excerpt,
          data: {
            ...post.data,
            url: post.data.url || null
          }
        });
      }
      else {
        acc.regular.push({...post, readingTime, excerpt});
      }
    }

    // Track tag counts
    tags.forEach(tag => {
      acc.tagCounts[tag] = (acc.tagCounts[tag] || 0) + 1;
    });

    // Add to total word count
    acc.totalWords += post.body ? post.body.split(/\s+/).length : 0;

    return acc;
  }, {
    regular: [],
    roughNotes: [],
    projects: [],
    books: [],
    curiosities: [],
    tagCounts: {},
    totalWords: 0
  });
});

// Sort posts once - ensure reverse chronological order
posts.regular.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
posts.roughNotes.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
posts.curiosities.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
posts.projects.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Projects found successfully

// Get top tags, excluding 'rough-notes'
const topTags = Object.entries(posts.tagCounts as Record<string, number>)
  .filter(([tag]) => tag !== 'rough-notes' && tag !== 'books')
  .sort(([, a], [, b]) => Number(b) - Number(a))
  .slice(0, 20)
  .reduce<Record<string, number>>((obj, [tag, count]) => ({ ...obj, [tag]: Number(count) }), {});

// Use pre-computed data
const latestPosts = posts.regular.slice(0, 3);
const remainingPosts = posts.regular.slice(3, 23); // Show only 10 essays after the latest posts

// Precompute formatted dates during build
const precomputedDates = new Map();
const formatDate = (date: string | Date) => {
  const dateStr = date.toString();
  if (!precomputedDates.has(dateStr)) {
    precomputedDates.set(dateStr, new Date(date).toLocaleDateString('en-GB', {
      day: '2-digit',
      month: 'short',
      year: 'numeric'
    }).replace(/ /g, ' '));
  }
  return precomputedDates.get(dateStr);
};

// Function to get clean slug without date prefix
const getCleanSlug = (slug: string) => slug.split('-').slice(3).join('-');
---

<BaseLayout title="Shreyas" showMainFooterSection={false}>
  <ViewTransitions client:only />
  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-2 sm:py-4">
    <section class="homepage-intro mt-8 mb-12 max-w-4xl">
      <div class="intro-copy text-gray-800 dark:text-gray-200 leading-relaxed space-y-4">
        <p>Hi! I'm Shreyas. I'm a Product Manager working at <a href="https://nature.com/" class="underline hover:no-underline" target="_blank" rel="noopener noreferrer">Springer Nature</a>. I like trying to understand the world, building things that improve it, and talking about it on the Internet.</p>
        <p>I like creating things—essays, websites, scripts, products. Anything which is positive sum, and impactful.</p>
        <p>Writing is thinking. It's something I deeply enjoy. 10 years from now, or a 100, It might probably outlive me. This is an attempt at that posterity. I write about what I'm building, what I'm learning, and the ideas I'm exploring:</p>
      </div>
      <figure class="intro-portrait">
        <img
          id="propic"
          src="/images/og/avatar-circle.png"
          width="480"
          height="480"
          alt="Portrait of Shreyas Prakash"
          loading="eager"
          decoding="async"
        />
      </figure>
    </section>

    <section class="my-8">
      <h2 class="text-2xl sm:text-3xl font-medium text-gray-600 dark:text-gray-400 mb-4">Themes</h2>
      <div class="flex flex-wrap items-center text-gray-800 dark:text-gray-200 leading-relaxed gap-y-2" style="word-break: break-word;">
        {Object.keys(topTags).map((tag) => (
          <span class="flex items-baseline gap-2 mr-4">
            <span class="text-gray-400 dark:text-gray-600" aria-hidden="true">•</span>
            <a 
              href={`/tags/${tag}`} 
              class="underline hover:no-underline text-gray-800 dark:text-gray-200 hover:text-gray-600 dark:hover:text-gray-400"
              style="text-decoration-skip-ink: auto; text-underline-position: under;"
              title={`View posts tagged "${tag}"`}
            >{tag}</a>
          </span>
        ))}
      </div>
    </section>

        <!-- Latest section -->
    <section class="mt-12 pt-10 mb-16 border-t border-gray-200 dark:border-gray-800">
      <h2 class="text-2xl sm:text-3xl font-normal text-gray-600 dark:text-gray-400 mb-6 sm:mb-8">Recently published</h2>
      <div class="space-y-8 sm:space-y-12">
        {latestPosts.map((post) => (
          <article class="group">
            <a href={`/${post.slug}`} class="block space-y-2">
              <h3 class="text-2xl sm:text-3xl font-normal text-gray-900 dark:text-gray-100 group-hover:text-gray-600 dark:group-hover:text-gray-400 underline underline-offset-4 decoration-1">
                {post.data.title}
              </h3>
              <div class="text-gray-600 dark:text-gray-400 text-base sm:text-lg">
                {formatDate(post.data.date)} — {post.readingTime}
              </div>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed text-lg sm:text-xl">
                {post.excerpt}
              </p>
            </a>
          </article>
        ))}
      </div>
    </section>


    <!-- Add visual separator -->
    <div class="my-20 border-t border-gray-200 dark:border-gray-800"></div>

    <section class="mt-12">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-2xl sm:text-3xl font-normal text-gray-600 dark:text-gray-400">Essays</h2>
        <div class="flex items-center text-base sm:text-lg text-gray-500 dark:text-gray-400">
          <span>{posts.regular.length} posts</span>
          {posts.regular.length > 13 && (
            <>
              <span class="mx-2 text-gray-300 dark:text-gray-700">|</span>
              <a href="/posts" class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 underline underline-offset-4">
                More essays →
              </a>
            </>
          )}
        </div>
      </div>
      <div class="space-y-2">
        {posts.regular.slice(3).map((post) => {
          const postDate = new Date(post.data.date);
          const year = postDate.getFullYear();
          
          return (
            <div class="flex items-baseline gap-4">
              <span class="text-gray-500 dark:text-gray-400 text-base sm:text-lg font-mono tabular-nums min-w-fit">
                {year}
              </span>
              <a 
                href={`/${post.slug}`} 
                class="text-xl sm:text-2xl text-gray-900 dark:text-gray-100 hover:text-gray-600 dark:hover:text-gray-400 underline underline-offset-4 decoration-1"
              >
                {post.data.title}
              </a>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Add visual separator before interviews -->
    <div class="my-20 border-t border-gray-200 dark:border-gray-800"></div>

    <!-- Interviews Section -->
    {interviews.length > 0 && (
      <section class="mb-16">
        <div class="flex items-baseline justify-between mb-8">
          <h2 class="text-2xl sm:text-3xl font-normal text-gray-600 dark:text-gray-400">Interviews</h2>
          <div class="flex items-center text-base sm:text-lg text-gray-500 dark:text-gray-400">
            <span>{interviews.length} interviews</span>
            <span class="mx-2 text-gray-300 dark:text-gray-700">|</span>
            <a href="/interviews" class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 underline underline-offset-4">
              View all →
            </a>
          </div>
        </div>
        <div class="space-y-2">
          {interviews.slice(0, 10).map((interview) => {
            const postDate = new Date(interview.data.date);
            const year = postDate.getFullYear();
            
            return (
              <div class="flex items-baseline gap-4">
                <span class="text-gray-500 dark:text-gray-400 text-base sm:text-lg font-mono tabular-nums min-w-fit">
                  {year}
                </span>
                <a 
                  href={`/${interview.slug}`} 
                  class="text-xl sm:text-2xl text-gray-900 dark:text-gray-100 hover:text-gray-600 dark:hover:text-gray-400 underline underline-offset-4 decoration-1"
                >
                  {interview.data.title}
                </a>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- Add visual separator before rough notes -->
    <div class="my-20 border-t border-gray-200 dark:border-gray-800"></div>

     <!-- Rough Notes Section -->
    {posts.roughNotes.length > 0 && (
      <section class="mb-16">
        <div class="flex items-baseline justify-between mb-8">
          <h2 class="text-2xl sm:text-3xl font-normal text-gray-600 dark:text-gray-400">Notes</h2>
          <div class="flex items-center text-base sm:text-lg text-gray-500 dark:text-gray-400">
            <span>{posts.roughNotes.length} posts</span>
            {posts.roughNotes.length > 20 && (
              <>
                <span class="mx-2 text-gray-300 dark:text-gray-700">|</span>
                <a href="/tags/rough-notes" class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 underline underline-offset-4">
                  Read notes →
                </a>
              </>
            )}
          </div>
        </div>
        <div class="space-y-2">
          {posts.roughNotes.map((post) => {
            const postDate = new Date(post.data.date);
            const year = postDate.getFullYear();
            
            return (
              <div class="flex items-baseline gap-4">
                <span class="text-gray-500 dark:text-gray-400 text-base sm:text-lg font-mono tabular-nums min-w-fit">
                  {year}
                </span>
                <a 
                  href={`/${post.slug}`} 
                  class="text-xl sm:text-2xl text-gray-900 dark:text-gray-100 hover:text-gray-600 dark:hover:text-gray-400 underline underline-offset-4 decoration-1"
                >
                  {post.data.title}
                </a>
              </div>
            );
          })}
        </div>
      </section>
    )}

  </main>
</BaseLayout>

<style>
  .homepage-intro {
    display: grid;
    gap: var(--space-200);
    align-items: start;
  }

  .intro-copy {
    min-width: 0;
  }

  .intro-portrait {
    order: -1;
    margin: 0 auto;
    width: min(100%, 14rem);
  }

  .intro-portrait img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-pill);
  }

  @media (min-width: 768px) {
    .homepage-intro {
      grid-template-columns: minmax(0, 1fr) minmax(16rem, 1fr);
      gap: var(--space-400);
    }

    .intro-portrait {
      order: 0;
      justify-self: end;
      align-self: start;
      width: min(100%, 44rem);
      margin: 0;
      position: sticky;
      top: var(--space-200);
    }

    .intro-portrait img {
      max-width: 36rem;
    }
  }
</style>

<style>
  /* Clean, minimal styling */
  :root {
    --text-primary: #000;
    --text-secondary: #666;
    --hover-color: #555;
  }

  main {
    color: var(--text-primary);
    font-size: var(--font-size-prose);
    line-height: var(--line-height-prose);
  }

  h1 {
    font-weight: 400;
    color: var(--text-primary);
  }

  /* Only apply hover effects on larger screens */
  @media (min-width: 640px) {
    a:hover {
      color: var(--hover-color);
    }
  }

  ul {
    list-style: none;
    padding: 0;
  }

  /* Dark mode support */
  @media (prefers-color-scheme: dark) {
    :root {
      --text-primary: #e1e1e1;
      --text-secondary: #a1a1a1;
      --hover-color: #fff;
    }
  }

</style> 
