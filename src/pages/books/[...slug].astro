---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Books from '../../components/Books';

export const prerender = true;

export async function getStaticPaths() {
  const books = await getCollection('posts', ({ data, id }) => {
    return !data.draft && 
           data.tags?.includes('books');
  });

  return [
    { params: { slug: undefined } }, // Handle base /books/ route
    ...books.map(book => ({
      params: { 
        // Keep slug as a single string
        slug: book.slug.replace('booknotes/', '')
      },
      props: { book }
    }))
  ];
}

const { slug } = Astro.params;

// Handle both string and array formats
const normalizedSlug = Array.isArray(slug) ? slug.join('/') : slug;

if (!normalizedSlug) {
  return Astro.redirect('/404');
}

const { book } = Astro.props;
const { Content } = await book.render();

const allBooks = await getCollection('posts', ({ data }) => {
  return !data.draft && data.tags?.includes('books');
}).then(posts => posts.sort((a, b) => 
  (b.data.rating || 0) - (a.data.rating || 0)
).map(post => ({
  title: post.data.title,
  slug: post.slug,
  author: post.data.author,
  rating: post.data.rating,
  date: post.data.date,
  summary: post.data.summary,
  cover: post.data.cover ? `/images/books/${post.data.cover.split('/').pop()}` : undefined
})));

// Format date like "July 29, 2023"
const formatDate = (date: string) => {
  return new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<BaseLayout title={`${book.data.title} | Shreyas Prakash`}>
  <main class="max-w-3xl mx-auto px-4 py-8">
    <div class="relative w-full overflow-hidden mb-16">
      <Books books={allBooks} client:load />
    </div>

    <article class="mb-16">
      <header class="mb-12">
        <h1 class="text-xl font-medium text-gray-900 dark:text-gray-100">
          {book.data.title}
        </h1>
        <div class="mt-2 text-sm text-gray-600 dark:text-gray-400 space-x-2">
          <span>By: {book.data.author}</span>
          <span>—</span>
          <span>Read: {formatDate(book.data.date)}</span>
          <span>—</span>
          <span>Rating: {book.data.rating}/10</span>
        </div>
        
        {book.data.summary && (
          <div class="mt-6 p-4 border border-gray-300 dark:border-gray-700 rounded-lg">
            <p class="text-gray-700 dark:text-gray-300">
              {book.data.summary}
            </p>
          </div>
        )}
      </header>
      
      <div class="prose prose-sm dark:prose-invert prose-neutral max-w-none book-content-prose
                  prose-headings:font-medium prose-headings:text-gray-900 dark:prose-headings:text-gray-100
                  prose-p:text-gray-800 dark:prose-p:text-gray-300
                  prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline
                  prose-strong:font-medium prose-strong:text-gray-900 dark:prose-strong:text-gray-100
                  prose-code:text-gray-900 dark:prose-code:text-gray-100
                  prose-pre:bg-gray-100 dark:prose-pre:bg-gray-800
                  prose-blockquote:text-gray-700 dark:prose-blockquote:text-gray-400
                  prose-hr:border-gray-200 dark:prose-hr:border-gray-800
                  prose-li:text-gray-800 dark:prose-li:text-gray-300">
        <Content />
      </div>
    </article>

    <section class="mt-16 mb-32 pt-8 border-t border-gray-200 dark:border-gray-800">
      <h2 class="text-xl font-medium text-gray-900 dark:text-gray-100 mb-8">
        Other books
      </h2>
      
      <div class="space-y-12">
        {allBooks
          .filter(otherBook => otherBook.slug !== book.slug)
          .sort(() => Math.random() - 0.5)  // Randomize the order
          .slice(0, 3)  // Show only 3 random books
          .map((otherBook) => (
            <article class="group">
              <div class="flex gap-6">
                <div class="w-24 h-36 flex-shrink-0">
                  <img
                    src={otherBook.cover || '/images/placeholder-book-cover.jpg'}
                    alt={otherBook.title}
                    class="h-full w-full object-cover border border-gray-200 dark:border-gray-800"
                  />
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-xl font-medium text-gray-900 dark:text-gray-100">
                    <a href={`/books/${otherBook.slug.replace('booknotes/', '')}`} class="hover:underline">
                      {otherBook.title}
                    </a>
                  </h3>
                  <p class="mt-1 text-gray-600 dark:text-gray-400">
                    {otherBook.author}
                  </p>
                  <p class="mt-1 text-sm text-gray-500">
                    Read: {formatDate(otherBook.date)} — Rating: {otherBook.rating}/10
                  </p>
                  {otherBook.summary && (
                    <p class="mt-3 text-gray-600 dark:text-gray-400 line-clamp-3">
                      {otherBook.summary}
                    </p>
                  )}
                </div>
              </div>
            </article>
          ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Make book content font size smaller and more consistent */
  .book-content-prose {
    font-size: 0.95rem;
    line-height: 1.6;
  }
  
  .book-content-prose p {
    font-size: 0.95rem !important;
    margin-bottom: 1rem;
  }
  
  .book-content-prose h1 {
    font-size: 1.3rem !important;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  .book-content-prose h2 {
    font-size: 1.2rem !important;
    margin-top: 1.8rem;
    margin-bottom: 0.8rem;
  }
  
  .book-content-prose h3 {
    font-size: 1.1rem !important;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  
  .book-content-prose h4, .book-content-prose h5, .book-content-prose h6 {
    font-size: 1rem !important;
    margin-top: 1.3rem;
    margin-bottom: 0.6rem;
  }
  
  .book-content-prose ul, .book-content-prose ol {
    font-size: 0.95rem;
  }
  
  .book-content-prose li {
    font-size: 0.95rem !important;
    margin-bottom: 0.5rem;
  }
  
  .book-content-prose blockquote {
    font-size: 0.95rem !important;
    font-style: italic;
    padding: 1rem;
    margin: 1.5rem 0;
  }
  
  .book-content-prose code {
    font-size: 0.9rem !important;
  }
  
  .book-content-prose pre {
    font-size: 0.85rem !important;
  }
</style> 