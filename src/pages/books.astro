---
import BaseLayout from '../layouts/BaseLayout.astro';
import BooksComponent from '../components/Books';
import { getCollection } from 'astro:content';

// Add prerender option to fix the warning
export const prerender = true;

const bookPosts = await getCollection('posts', ({ data }) => {
  // Handle both array formats and ensure we check for 'books' tag inclusively
  return !data.draft && (
    (Array.isArray(data.tags) && data.tags.some(tag => 
      typeof tag === 'string' && tag.toLowerCase() === 'books'
    )) || 
    (data.tags?.includes('books'))
  );
}).then(posts => {
  // Create a copy of the array and shuffle it
  const shuffledPosts = [...posts];
  for (let i = shuffledPosts.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffledPosts[i], shuffledPosts[j]] = [shuffledPosts[j], shuffledPosts[i]];
  }
  return shuffledPosts;
});

// Render the content for each book
const booksWithContent = await Promise.all(
  bookPosts.map(async (book) => {
    const { Content } = await book.render();
    return {
      ...book,
      Content
    };
  })
);

const resolvedBooks = booksWithContent.map(book => ({
  title: book.data.title,
  slug: book.slug,
  author: book.data.author,
  rating: book.data.rating,
  date: book.data.date,
  summary: book.data.summary,
  cover: book.data.cover ? `/images/books/${book.data.cover.split('/').pop()}` : undefined,
  Content: book.Content
}));

// Format date like "July 29, 2023"
const formatDate = (date: string) => {
  return new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<BaseLayout title="Books | Shreyas Prakash" showMainFooterSection={true}>
  <main class="max-w-4xl mx-auto px-4 pt-16 sm:pt-32 pb-8">
    <div class="relative w-full overflow-hidden mb-24" id="bookshelf-section">
      <BooksComponent books={resolvedBooks} client:visible />
    </div>

    <div class="space-y-12">
      {resolvedBooks.map((book) => (
        <div class="book-container max-w-4xl mx-auto">
          <div class="book-cover">
            <img
              src={book.cover || '/images/placeholder-book-cover.jpg'}
              alt={`Cover of ${book.title}`}
              class="h-full w-full object-cover border border-gray-200 dark:border-gray-800"
              loading="lazy"
              decoding="async"
              width="200"
              height="300"
            />
          </div>
          <div class="book-content">
            <h2 id={book.slug} class="text-2xl sm:text-3xl font-medium text-gray-900 dark:text-gray-100 scroll-mt-32">
              <a href={`/books/${book.slug.replace('booknotes/', '')}`} class="hover:underline">
                {book.title}
              </a>
            </h2>
            <p class="mt-1 text-gray-600 dark:text-gray-400">
              {book.author}
            </p>
            <p class="mt-1 text-lg text-gray-500">
              Read: {formatDate(book.date)} — Rating: {book.rating}/10
            </p>
            <div class="mt-6 prose dark:prose-invert max-w-none book-prose">
              <book.Content />
            </div>
          </div>
        </div>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  html {
    scroll-behavior: smooth;
  }

  .book-container {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
    margin-bottom: 4rem;
    position: relative;
    padding-bottom: 4rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .book-container:last-child {
    border-bottom: none;
  }

  .book-cover {
    position: sticky;
    top: 20vh; /* Less extreme than middle of viewport */
    transform: none; /* Remove the transform */
    align-self: start;
    max-width: 200px;
    height: auto;
  }

  .book-content {
    padding-bottom: 2rem;
  }

  /* Make book content font size more consistent with other sections */
  .book-prose {
    font-size: 1.2rem;
    line-height: 1.8;
  }
  
  .book-prose p {
    font-size: inherit;
    margin-bottom: 1.25rem;
  }
  
  .book-prose h1, .book-prose h2, .book-prose h3, .book-prose h4, .book-prose h5, .book-prose h6 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 1.75rem;
    margin-bottom: 1rem;
  }
  
  .book-prose ul, .book-prose ol {
    font-size: inherit;
  }
  
  .book-prose blockquote {
    font-size: inherit;
    font-style: italic;
  }

  /* Add visual separation between book titles and content */
  .book-content h2 {
    padding-bottom: 0.75rem;
    margin-bottom: 1rem;
    border-bottom: 2px solid rgba(0, 0, 0, 0.05);
  }

  @media (max-width: 768px) {
    .book-container {
      grid-template-columns: 1fr;
    }
    
    .book-cover {
      position: relative;
      top: 0;
      margin-bottom: 1rem;
    }
  }

  /* Dark mode support for borders */
  @media (prefers-color-scheme: dark) {
    .book-container {
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .book-content h2 {
      border-bottom: 2px solid rgba(255, 255, 255, 0.05);
    }
  }
</style> 
