---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { calculateReadingTime } from '../../utils/readingTime';
import { generateExcerpt } from '../../utils/excerptUtils';
import type { CollectionEntry } from 'astro:content';

// Format date helper function - handles both formats
const formatDate = (date: string | Date) => {
  if (!date) return '';
  
  try {
    const dateObj = new Date(date);
    if (isNaN(dateObj.getTime())) {
      throw new Error('Invalid date');
    }
    
    return dateObj.toLocaleDateString('en-GB', {
      day: '2-digit',
      month: 'short',
      year: 'numeric'
    }).replace(/ /g, ' ');
  } catch (error) {
    console.error('Error formatting date:', error);
    return 'Invalid date';
  }
};

// Helper function to get post summary
function getPostSummary(post: CollectionEntry<'posts'>) {
  if (post.data.summary) return post.data.summary;
  return generateExcerpt(post.body);
}

// Helper function to get stage emoji
function getStageEmoji(stage: string | undefined): string {
  if (!stage) return '';
  if (stage === 'seedling') return '🌱';
  if (stage === 'sprout') return '🌿';
  if (stage === 'plant') return '🌳';
  return '';
}

// Get first tag safely
function getFirstTag(tags: string[] | undefined): string | null {
  if (!tags || tags.length === 0) return null;
  const filteredTags = tags.filter(tag => tag !== 'rough-notes');
  return filteredTags.length > 0 ? filteredTags[0] : null;
}

// Helper for tag formatting
function formatTag(tag: string): string {
  if (!tag) return '';
  
  return tag
    .split('-')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

// Get all posts and their tags for generating routes
export async function getStaticPaths() {
  // Get all unique tags
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  
  // Debug log all unique tags extracted from posts
  const tags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];
  console.log("All available tags:", tags);
  
  return tags.map(tag => {
    return {
      params: { tag },
      props: { tag }
    };
  });
}

// IMPORTANT FIX: Get tag from params if not in props
const { tag: propTag } = Astro.props;
const { tag: paramTag } = Astro.params;
const tag = propTag || paramTag;

console.log("Current tag page from params:", paramTag);
console.log("Current tag page from props:", propTag);
console.log("Final tag being used:", tag);

// Early return for books tag
if (tag === 'books') {
  return Astro.redirect('/books');
}

// Continue with normal tag page processing for other tags

// Log all posts and their tags for debugging
const allPostsForDebug = await getCollection('posts', ({ data }) => !data.draft);
console.log("Total non-draft posts:", allPostsForDebug.length);

// Log each post's title and tags to help identify mismatches
allPostsForDebug.forEach(post => {
  console.log(`Post "${post.data.title}" has tags:`, post.data.tags);
  
  // Check specifically if this post has the current tag
  if (post.data.tags?.includes(tag)) {
    console.log(`✅ Post "${post.data.title}" MATCHES current tag "${tag}"`);
  } else {
    console.log(`❌ Post "${post.data.title}" does NOT match current tag "${tag}"`);
  }
});

// Sort posts by date (newest first)
const posts = await getCollection('posts', ({ data }) => {
  const hasTag = data.tags?.includes(tag);
  console.log(`Checking post "${data.title}" for tag "${tag}": ${hasTag ? "MATCH" : "NO MATCH"}`);
  return !data.draft && hasTag;
});

console.log(`Found ${posts.length} posts with tag "${tag}"`);

const sortedPosts = posts.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

console.log("Sorted posts titles:", sortedPosts.map(p => p.data.title));

// Determine if this is the projects tag
const isProjectsTag = tag === 'projects';
const isRoughNotesTag = tag === 'rough-notes';
const isCuriositiesTag = tag === 'curiosities';
---

<BaseLayout title={`${formatTag(tag as string)} | Shreyas Prakash`} showMainFooterSection={true}>
  <main class="max-w-3xl mx-auto px-4 pt-16 sm:pt-32 pb-8 min-h-[85vh]">
    <header class="mb-12">
      <h1 class="text-3xl font-normal text-gray-900 dark:text-gray-200 mb-2">{formatTag(tag as string)}</h1>
      {tag === 'rough-notes' && (
        <p class="mt-2 text-gray-600 dark:text-gray-400">
          These are quick, unpolished thoughts. Think of them as seedlings in my digital garden - they might grow into fully-formed essays over time.
        </p>
      )}
      {tag === 'projects' && (
        <p class="mt-4 text-gray-600 dark:text-gray-400">
          Compilation of some of my extensive projects which has significantly occupied my attention over the years. After all, What is life if not for a series of projects? 
        </p>
      )}
      <div class="mt-4 text-gray-500 dark:text-gray-400 text-sm">
        {posts.length} post{posts.length === 1 ? '' : 's'}
      </div>
    </header>

    <section>
      {isProjectsTag ? (
        <div>
          <div>
            {sortedPosts.map((post) => (
              <div class="py-12 first:pt-0 last:pb-0">
                <div class="space-y-2">
                  <div>
                    <a 
                      href={`/posts/${post.slug}`}
                      class="group"
                    >
                      <h2 class="text-lg font-normal text-gray-800 dark:text-gray-200 group-hover:text-gray-600 dark:group-hover:text-gray-400 mb-2 underline underline-offset-4 decoration-gray-300 dark:decoration-gray-700">
                        {post.data.title}
                      </h2>
                    </a>
                  </div>
                  <div class="text-gray-500 dark:text-gray-400 text-sm mb-2">
                    {formatDate(post.data.date)}
                  </div>
                  {post.body && (
                    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                      {getPostSummary(post)}
                    </p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      ) : isRoughNotesTag ? (
        <ul class="space-y-12">
          {sortedPosts.map(post => {
            const summary = getPostSummary(post);
            const stageEmoji = getStageEmoji(post.data.stage);
            const displayTag = getFirstTag(post.data.tags);
            const readingTime = calculateReadingTime(post.body);
            const formattedDate = formatDate(post.data.date);
            
            return (
              <li class="group">
                <div class="mb-2">
                  <a 
                    href={`/posts/${post.slug}`} 
                    class="text-xl font-normal text-gray-800 dark:text-gray-200 group-hover:text-gray-600 dark:group-hover:text-gray-400 underline underline-offset-4 decoration-gray-300 dark:decoration-gray-700"
                  >
                    {post.data.title}
                  </a>
                </div>
                <div class="mb-3 flex items-center space-x-2">
                  {displayTag && (
                    <a href={`/tags/${displayTag}`} class="text-xs text-gray-500 dark:text-gray-400 font-['JetBrains_Mono'] tracking-tight hover:text-gray-800 dark:hover:text-gray-200">
                      {displayTag}
                    </a>
                  )}
                  <span class="text-xs text-gray-500 dark:text-gray-400">
                    {stageEmoji && <span class="mr-1">{stageEmoji}</span>}
                    {readingTime} — {formattedDate}
                  </span>
                </div>
                <p class="text-gray-600 dark:text-gray-400 text-sm">
                  {summary}
                </p>
              </li>
            );
          })}
        </ul>
      ) : isCuriositiesTag ? (
        <ul class="space-y-12">
          {sortedPosts.map(post => {
            const summary = getPostSummary(post);
            const stageEmoji = getStageEmoji(post.data.stage);
            
            return (
              <li class="group grid grid-cols-1 sm:grid-cols-[1fr_auto] items-start sm:items-baseline gap-1 sm:gap-6">
                <div class="min-w-0">
                  <a 
                    href={`/posts/${post.slug}`} 
                    class="text-xl font-normal text-gray-800 dark:text-gray-200 group-hover:text-gray-600 dark:group-hover:text-gray-400 underline underline-offset-4 decoration-gray-300 dark:decoration-gray-700"
                  >
                    {post.data.title}
                  </a>
                  <div class="text-gray-600 dark:text-gray-400 text-sm mt-2">
                    {post.data.description || summary}
                  </div>
                </div>
                {post.data.url ? (
                  <a href={post.data.url} target="_blank" rel="noopener noreferrer" class="text-xs text-gray-500 dark:text-gray-400 font-['JetBrains_Mono'] tracking-tight hover:text-gray-800 dark:hover:text-gray-200 sm:whitespace-nowrap">
                    ↗ GitHub
                  </a>
                ) : post.data.tags && post.data.tags.length > 0 && post.data.tags.find(t => t !== 'curiosities') && (
                  <span class="text-xs text-gray-500 dark:text-gray-400 font-['JetBrains_Mono'] tracking-tight sm:whitespace-nowrap">
                    {post.data.tags.find(t => t !== 'curiosities')}
                  </span>
                )}
              </li>
            );
          })}
        </ul>
      ) : (
        <div>
          <div>
            {sortedPosts.map(post => {
              const summary = getPostSummary(post);
              const stageEmoji = getStageEmoji(post.data.stage);
              const readingTime = calculateReadingTime(post.body);
              const formattedDate = formatDate(post.data.date);
              
              return (
                <div class="border-b border-gray-200 dark:border-gray-800 py-10 first:pt-0 last:border-0">
                  <div class="first:pt-0 last:pb-0">
                    <div class="mb-2">
                      <a 
                        href={`/posts/${post.slug}`}
                        class="group"
                      >
                        <h2 class="text-lg font-normal text-gray-800 dark:text-gray-200 group-hover:text-gray-600 dark:group-hover:text-gray-400 underline underline-offset-4 decoration-gray-300 dark:decoration-gray-700">
                          {post.data.title}
                        </h2>
                      </a>
                    </div>
                    
                    <div class="flex items-center space-x-2 mb-3">
                      {post.data.tags && post.data.tags.length > 0 && post.data.tags[0] !== tag && (
                        <a 
                          href={`/tags/${post.data.tags[0]}`} 
                          class="text-xs text-gray-500 dark:text-gray-400 font-['JetBrains_Mono'] tracking-tight hover:text-gray-800 dark:hover:text-gray-200"
                        >
                          {post.data.tags[0]}
                        </a>
                      )} 
                      <span class="text-xs text-gray-500 dark:text-gray-400">
                        {stageEmoji && <span class="mr-1">{stageEmoji}</span>}
                        {readingTime} — {formattedDate}
                      </span>
                    </div>
                    
                    {post.body && (
                      <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                        {summary}
                      </p>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}
    </section>

    <div class="mt-16 pb-8">
      <a 
        href="/" 
        class="text-gray-500 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-200 transition-colors underline underline-offset-4 decoration-gray-300 dark:decoration-gray-700"
      >
        ← Back to home
      </a>
    </div>
  </main>
</BaseLayout> 