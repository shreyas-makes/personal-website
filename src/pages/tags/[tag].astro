---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { calculateReadingTime } from '../../utils/readingTime';
import { generateExcerpt } from '../../utils/excerptUtils';
import type { CollectionEntry } from 'astro:content';

// Format date helper function - handles both formats
const formatDate = (date: string | Date) => {
  if (!date) return '';
  
  try {
    const dateObj = new Date(date);
    if (isNaN(dateObj.getTime())) {
      throw new Error('Invalid date');
    }
    
    return dateObj.toLocaleDateString('en-GB', {
      day: '2-digit',
      month: 'short',
      year: 'numeric'
    }).replace(/ /g, ' ');
  } catch (error) {
    console.error('Error formatting date:', error);
    return 'Invalid date';
  }
};

// Helper function to get post summary
function getPostSummary(post: CollectionEntry<'posts'>) {
  if (post.data.summary) return post.data.summary;
  return generateExcerpt(post.body);
}

// Helper function to get stage emoji
function getStageEmoji(stage: string | undefined): string {
  if (!stage) return '';
  if (stage === 'seedling') return '🌱';
  if (stage === 'sprout') return '🌿';
  if (stage === 'plant') return '🌳';
  return '';
}

// Get first tag safely
function getFirstTag(tags: string[] | undefined): string | null {
  if (!tags || tags.length === 0) return null;
  const filteredTags = tags.filter(tag => tag !== 'rough-notes');
  return filteredTags.length > 0 ? filteredTags[0] : null;
}

// Helper for tag formatting
function formatTag(tag: string): string {
  if (!tag) return '';
  
  return tag
    .split('-')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

// Get all posts and their tags for generating routes
export async function getStaticPaths() {
  // Get all unique tags
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  
  // Debug log all unique tags extracted from posts
  const tags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];
  console.log("All available tags:", tags);
  
  return tags.map(tag => {
    return {
      params: { tag },
      props: { tag }
    };
  });
}

// IMPORTANT FIX: Get tag from params if not in props
const { tag: propTag } = Astro.props;
const { tag: paramTag } = Astro.params;
const tag = propTag || paramTag;

console.log("Current tag page from params:", paramTag);
console.log("Current tag page from props:", propTag);
console.log("Final tag being used:", tag);

// Early return for books tag
if (tag === 'books') {
  return Astro.redirect('/books');
}

// Continue with normal tag page processing for other tags

// Log all posts and their tags for debugging
const allPostsForDebug = await getCollection('posts', ({ data }) => !data.draft);
console.log("Total non-draft posts:", allPostsForDebug.length);

// Log each post's title and tags to help identify mismatches
allPostsForDebug.forEach(post => {
  console.log(`Post "${post.data.title}" has tags:`, post.data.tags);
  
  // Check specifically if this post has the current tag
  if (post.data.tags?.includes(tag)) {
    console.log(`✅ Post "${post.data.title}" MATCHES current tag "${tag}"`);
  } else {
    console.log(`❌ Post "${post.data.title}" does NOT match current tag "${tag}"`);
  }
});

// Sort posts by date (newest first)
const posts = await getCollection('posts', ({ data }) => {
  const hasTag = data.tags?.includes(tag);
  console.log(`Checking post "${data.title}" for tag "${tag}": ${hasTag ? "MATCH" : "NO MATCH"}`);
  return !data.draft && hasTag;
});

console.log(`Found ${posts.length} posts with tag "${tag}"`);

const sortedPosts = posts.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

console.log("Sorted posts titles:", sortedPosts.map(p => p.data.title));

// Determine if this is the projects tag
const isProjectsTag = tag === 'projects';
const isRoughNotesTag = tag === 'rough-notes';
const isCuriositiesTag = tag === 'curiosities';
---

<BaseLayout title={`${formatTag(tag as string)} | Shreyas Prakash`} showMainFooterSection={true}>
  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-12">

    <section class="mt-8 sm:mt-16 md:mt-24 mb-20">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-xl font-normal text-gray-600 dark:text-gray-400">{formatTag(tag as string)}</h2>
        <div class="flex items-center text-sm text-gray-500 dark:text-gray-400">
          <span>{posts.length} post{posts.length === 1 ? '' : 's'}</span>
        </div>
      </div>
      <ul class="space-y-12">
        {sortedPosts.map((post) => {
          const summary = getPostSummary(post);
          const readingTime = calculateReadingTime(post.body);
          const formattedDate = formatDate(post.data.date);
          
          return (
            <li class="flex flex-col gap-1">
              <div class="flex flex-col space-y-1">
                <a href={`/${post.slug}`} 
                   class="text-gray-800 dark:text-gray-200 hover:text-gray-600 dark:hover:text-gray-400 block underline underline-offset-4 decoration-1">
                  <span class="block text-ellipsis overflow-hidden">
                    {post.data.title}
                  </span>
                </a>
                <span class="text-gray-500 dark:text-gray-400 text-xs">
                  {readingTime} <span class="mx-2"> — </span> {formattedDate}
                </span>
                <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                  {summary}
                </p>
              </div>
            </li>
          );
        })}
      </ul>
    </section>

    <div class="mt-16 pb-8">
      <a 
        href="/" 
        class="text-gray-500 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-200 transition-colors underline underline-offset-4 decoration-gray-300 dark:decoration-gray-700"
      >
        ← Back to home
      </a>
    </div>
  </main>
</BaseLayout> 