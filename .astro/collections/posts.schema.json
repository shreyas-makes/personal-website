{
  "$ref": "#/definitions/posts",
  "definitions": {
    "posts": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "slug": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "author": {
          "type": "string"
        },
        "rating": {
          "type": "number",
          "minimum": 1,
          "maximum": 10
        },
        "summary": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "cover": {
          "type": "string"
        },
        "isbn": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "stage": {
          "type": "string",
          "enum": [
            "seedling",
            "sprout",
            "plant"
          ],
          "default": "seedling"
        }
      },
      "required": [
        "title",
        "date"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}